<style>
    .osc-browser-page {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        gap: 16px;
        padding: 16px;
        box-sizing: border-box;
    }

    .osc-browser-header,
    .osc-browser-footer {
        flex: 0 0 auto;
    }

    .osc-browser-results {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

</style>

<div class="osc-browser-page">

    @if (Header != null)
    {
        <div class="osc-browser-header">
            @Header
        </div>
    }

    <div class="osc-browser-results">
        @Results
    </div>

    @if (Footer != null)
    {
        <div class="osc-browser-footer">
            @Footer
        </div>
    }

</div>



@code {
    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter] public RenderFragment Results { get; set; } = default!;
    [Parameter] public RenderFragment? Footer { get; set; } = default!;
}

