@using Microsoft.Extensions.Localization
@using MudBlazor
@using OtherSideCore.Application.Interfaces
@using OtherSideCore.Domain
@using OtherSideCore.WebUI.Interfaces

@inject ILocalizedStringService LocalizedStringService

<style>
    .osc-icon-circle {
        width: 36px;
        height: 36px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-primary);
    }

    .osc-icon-circle__icon {
        color: var(--mud-palette-primary-text) !important;
    }
</style>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="osc-module-header">

    <MudPaper Class="osc-icon-circle" Elevation="0">
        <MudIcon Icon="@Icon" Style="color:var(--mud-palette-white) !important;" Size="Size.Medium" />
    </MudPaper>

    <MudText Typo="@Typo" Style="color:var(--mud-palette-text-primary) !important; font-weight:500">@Title</MudText>

</MudStack>

@code {
    [Parameter] public string? Icon { get; set; } = Icons.Material.Sharp.Block;
    [Parameter] public string Title { get; set; } = "Undefined";
    [Parameter] public Typo Typo { get; set; } = Typo.h5;
}
