@using MudBlazor
@using OtherSideCore.Application.Interfaces

@inject ILocalizedStringService LocalizedStringService

<MudDialog>
    <TitleContent>
        @LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.ConfirmationKey)
    </TitleContent>
    <DialogContent>
        @Message
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Ok">@LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.OkKey)</MudButton>
        <MudButton OnClick="Cancel">@LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.CancelKey)</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public string Message { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    private void Ok() => MudDialog?.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog?.Cancel();
}
