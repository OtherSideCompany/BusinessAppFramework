@using MudBlazor

@using OtherSideCore.Application.Interfaces
@using OtherSideCore.Domain.DomainObjects

@inject ILocalizedStringService LocalizedStringService

<MudText Typo="Typo.caption" Align="Align.Start" Style="color:gray; font-style: italic">@DisplayString</MudText>

@code {
    [CascadingParameter] public DomainObject? DomainObject { get; set; }

    public string CreatedInfo =>
        DomainObject == null
            ? ""
            : $"{DomainObject.CreationDate:dd/MM/yyyy HH:mm} {LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.ByKey)} {DomainObject.CreatedByName}";

    public string ModifiedInfo =>
        DomainObject?.LastModifiedDateTime == null
            ? ""
            : $"{DomainObject.LastModifiedDateTime:dd/MM/yyyy HH:mm} {LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.ByKey)} {DomainObject.LastModifiedByName}";

    public string DisplayString => $"{LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.CreationKey)} : {CreatedInfo}, {LocalizedStringService.Get(OtherSideCore.Contracts.StringKeys.LastModificationKey)?.ToLower()} : {ModifiedInfo}";
}
