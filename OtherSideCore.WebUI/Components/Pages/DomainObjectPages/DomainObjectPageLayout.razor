<style>
    .osc-domainobject-page {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        gap: 16px;
        box-sizing: border-box;
        padding:16px;
    }

    .osc-domainobject-header {
        flex: 0 0 auto;
        height:48px;
        display: flex;
        align-items: center;
    }

    .osc-domainobject-content {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

</style>

<div class="osc-domainobject-page">

    @if (Header != null)
    {
        <div class="osc-domainobject-header">
            @Header
        </div>
    }

    @if (Content != null)
    {
        <div class="osc-domainobject-content">
            @Content
        </div>
    }   
</div>

@code {
    [Parameter] public RenderFragment? Header { get; set; }
    [Parameter] public RenderFragment? Content { get; set; }
}