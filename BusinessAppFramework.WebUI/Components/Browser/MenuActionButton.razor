@using BusinessAppFramework.Application.Interfaces
@using Contracts
@using Domain
@using MudBlazor
@using WebUI.Interfaces

@inject IIconFactory IconFactory
@inject ILocalizedStringService LocalizedStringService

<style>
    .osc-btn {
        font-weight: normal;
        border-radius: 16px;
        text-transform: none;
        border: 0px;
        transition: background-color .15s, border-color .15s;
        height: 32px;
        min-height: 32px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .osc-btn-bordered {
        border: 1px solid var(--mud-palette-lines-inputs);
    }

    .osc-btn.mud-icon-button {
        border-radius: 16px !important;
        height: 32px;
        width: 32px;
        min-width: 32px;
        padding: 0;
    }

    .osc-btn--neutral {
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
    }

        .osc-btn--neutral:hover:not(:disabled) {
            background: #e4e6e9;
        }

        .osc-btn--neutral:active:not(:disabled) {
            background: #d6d9dd;
        }
</style>

<MudMenu Dense="true"
         Disabled="@Disabled">
    <ActivatorContent Context="context">
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   StartIcon="@IconFactory.CreateIcon(ActionKey)"
                   EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                   Disabled="@Disabled"
                   Ripple="false"
                   OnClick="@context.ToggleAsync"
                   Class="@_class">
            @LocalizedStringService.Get(ActionKey)
        </MudButton>
    </ActivatorContent>
    <ChildContent>
        @MenuItems
    </ChildContent>
</MudMenu>

@code {
    [Parameter] public string ActionKey { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? MenuItems { get; set; }
    [Parameter] public bool Bordered { get; set; }

    private string _class
    {
        get
        {
            var borderedClass = Bordered ? "osc-btn-bordered" : String.Empty;
            return $"osc-btn osc-btn--neutral {borderedClass}";
        }
    }
}
