@using BusinessAppFramework.Application.Interfaces
@using Contracts
@using Domain
@using MudBlazor
@using WebUI.Interfaces

@inject IIconFactory IconFactory
@inject ILocalizedStringService LocalizedStringService

<style>
    .osc-btn {
        font-weight: normal;
        border-radius: 16px;
        text-transform: none;     
        border: 0px;
        transition: background-color .15s, border-color .15s;
        height: 32px; 
        min-height: 32px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .osc-btn-bordered{
        border: 1px solid var(--mud-palette-lines-inputs);
    }

        .osc-btn.mud-icon-button {
            border-radius: 16px !important;
            height: 32px;
            width: 32px; 
            min-width: 32px;
            padding: 0;
        }

    .osc-btn--neutral {
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
    }

        .osc-btn--neutral:hover:not(:disabled) {
            background: #e4e6e9;
        }

        .osc-btn--neutral:active:not(:disabled) {
            background: #d6d9dd;
        }

    .osc-btn--create {
        background: var(--mud-palette-primary);
        color: #fff;
        border-color: var(--mud-palette-primary);
    }

        .osc-btn--create:hover:not(:disabled) {
            background: var(--mud-palette-primary-darken);
        }

        .osc-btn--create:active:not(:disabled) {
            background: var(--mud-palette-primary-darken);
        }

    .osc-btn--delete {
        background: var(--mud-palette-surface);
        color: var(--mud-palette-error);
        border-color: var(--mud-palette-divider);
    }

        .osc-btn--delete:hover:not(:disabled) {
            background: var(--mud-palette-error);
            color: #fff;
            border-color: var(--mud-palette-error);
        }

        .osc-btn--delete:active:not(:disabled) {
            background: var(--mud-palette-error-darken);
            color: #fff;
            border-color: var(--mud-palette-error-darken);
        }

    .osc-btn:disabled,
    .osc-btn.mud-disabled {
        opacity: .45;
        cursor: not-allowed;
    }
</style>

@if (Shrink)
{
    <MudTooltip Text="@LocalizedStringService.Get(ActionKey)">
        <MudIconButton Variant="Variant.Outlined"
                       Size="Size.Small"
                       Icon="@IconFactory.CreateIcon(ActionKey)"
                       OnClick="OnClickInternal"
                       Disabled="@Disabled"
                       Class="@_class">
        </MudIconButton>
    </MudTooltip>
}
else
{
    <MudButton Variant="Variant.Outlined"
               Size="Size.Small"
               StartIcon="@IconFactory.CreateIcon(ActionKey)"
               OnClick="OnClickInternal"
               Disabled="@Disabled"
               Class="@_class">
        @LocalizedStringService.Get(ActionKey)
    </MudButton>
}

@code {
    [Parameter] public string ActionKey { get; set; } = "";
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Shrink { get; set; }
    [Parameter] public bool Bordered { get; set; }

    private string _class
    {
        get
        {
            var role = ActionKey switch
            {
                ActionKeys.CreateActionKey => "osc-btn--create",
                ActionKeys.DeleteActionKey => "osc-btn--delete",
                _ => "osc-btn--neutral"
            };
            var borderedClass = Bordered ? "osc-btn-bordered" : String.Empty;
            return $"osc-btn {borderedClass} {role}";
        }
    }

    private async Task OnClickInternal(MouseEventArgs e)
    {
        if (Disabled)
            return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);
    }
}
