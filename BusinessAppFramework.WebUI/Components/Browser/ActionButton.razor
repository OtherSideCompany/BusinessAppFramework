@using BusinessAppFramework.Application.Interfaces
@using Contracts
@using Domain
@using MudBlazor
@using WebUI.Interfaces

@inject IIconFactory IconFactory
@inject ILocalizedStringService LocalizedStringService

<style>
    .osc-action-button {
        font-weight: normal;
        background: var(--mud-palette-surface);
        border-color: var(--mud-palette-divider);
        border-radius: 16px;
        padding: 4px 14px;
    }
        .osc-action-button:hover {
            background: var(--mud-palette-background-grey) !important;
            border-color: var(--mud-palette-divider) !important;
        }
</style>

<MudButton Variant="Variant.Outlined"           
           Size="Size.Small"
           StartIcon="@IconFactory.CreateIcon(ActionKey)"
           IconColor="@_color"
           OnClick="OnClickInternal"
           Disabled="@Disabled"
           Class="osc-action-button">
    @LocalizedStringService.Get(ActionKey.Key)
</MudButton>

@code {
    [Parameter] public StringKey ActionKey { get; set; } = StringKey.From("");
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private Color _color { get; set; }

    private async Task OnClickInternal(MouseEventArgs e)
    {
        if (Disabled) 
            return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ActionKey.Equals(StringKey.From(ActionKeys.CreateActionKey)))
        {
            _color = Color.Primary;
        }
        else if (ActionKey.Equals(StringKey.From(ActionKeys.DeleteActionKey)))
        {
            _color = Color.Error;
        }
        else
        {
            _color = Color.Dark;
        }
    }
}
