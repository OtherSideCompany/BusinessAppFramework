@using Application.Descriptors
@using BusinessAppFramework.Application.Interfaces
@using Application.Search
@using Domain.DomainObjects
@using Microsoft.AspNetCore.Components.Web;
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using MudBlazor
@using Application.Actions
@using Application.Browser
@using Domain
@using WebUI.Components.Editor
@using WebUI.Components.Header
@using WebUI.Components.Pages
@using WebUI.Components.SearchList
@using WebUI.Factories
@using WebUI.Interfaces

@inject ILocalizedStringService LocalizedStringService
@inject ISearchGateway<TSearchResult> SearchService
@inject IDomainObjectServiceGateway<TDomainObject> DomainObjectServiceGateway
@inject IIconFactory IconFactory
@inject IJSRuntime JS
@inject IDomainObjectBrowserWorkspaceRegistry DomainObjectBrowserWorkspaceRegistry

@typeparam TDomainObject where TDomainObject : DomainObject, new()
@typeparam TSearchResult where TSearchResult : DomainObjectSearchResult, new()

@implements IDomainObjectSelector

<style>
    .osc-search.mud-input-control {
        flex: 0 0 300px;
        max-width: 300px;
        min-width: 200px;
    }

        .osc-search.mud-input-control .mud-input {
            width: 100%;
        }

    .osc-search .mud-input-outlined-border {
        border-radius: 8px !important;
    }

    .osc-search .mud-input-outlined {
        border-radius: 8px !important;
    }    
</style>

<DomainObjectSelectorLayout>

    <Header>
        <MudStack Row="false">

            <MudText Typo="Typo.subtitle2">@LocalizedStringService.Get(Descriptor.WorkspaceKey.Key)</MudText>

            <MudStack Row="true" AlignItems="AlignItems.Center">

                <MudTextField T="string"
                              Class="osc-search"
                              Placeholder="@LocalizedStringService.Get(Contracts.StringKeys.SearchKey)"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Small"
                              Variant="Variant.Outlined"
                              Underline="false"
                              @bind-Value="_filter"
                              OnKeyUp="HandleKeyUp"
                              Margin="Margin.Dense"
                              Style="background: var(--mud-palette-surface);" />

                <MudText Typo="Typo.caption" Style="margin-top:4px; color:gray;">
                    @_totalItems @LocalizedStringService.Get(Contracts.StringKeys.ResultsKey)
                </MudText>

            </MudStack>

        </MudStack>
    </Header>

    <Results>
        <DynamicComponent Type="Descriptor.SearchListTemplateProviderType"
                          @ref="_templateComponent" />

        <MudDataGrid T="TSearchResult"
                     Dense="true"
                     Hover="true"
                     Elevation="0"
                     @ref="_grid"
                     ServerData="LoadGridData"
                     RowClass="cursor-pointer"
                     RowsPerPage="@_pageSize"
                     SelectedItemChanged="OnSelectedItemChangedAsync"
                     ReadOnly="true"
                     ColumnResizeMode="ResizeMode.Column">

            <Columns>
                @_searchListTemplateProvider?.Template?.DataGridColumns
            </Columns>

        </MudDataGrid>

    </Results>

    <Footer>

        <MudTooltip Text="@LocalizedStringService.Get(Contracts.StringKeys.NewKey)">
            <MudIconButton Icon="@Icons.Material.Sharp.Add"
                           Color="Color.Primary"
                           Variant="Variant.Text"
                           Size="Size.Small"
                           OnClick="OpenModuleInNewTab" 
                           Class="ml-2"/>
        </MudTooltip>

    </Footer>

</DomainObjectSelectorLayout>


@code {
    [Parameter] public DomainObjectSelectorDescriptor<TDomainObject, TSearchResult> Descriptor { get; set; } = default!;
    [Parameter] public EventCallback<int> OnItemSelected { get; set; }

    private string _filter { get; set; } = String.Empty;
    private string? _lastFilter;
    private string? _firstRenderFilter;
    private MudDataGrid<TSearchResult>? _grid;
    private DynamicComponent? _templateComponent;
    private ISearchListTemplateProvider<TSearchResult>? _searchListTemplateProvider => _templateComponent?.Instance as ISearchListTemplateProvider<TSearchResult>;

    private int _totalItems;
    private int _pageSize = 20;

    private bool _isLoadRequested = false;

    public async Task Load(string filter)
    {
        if (_grid != null)
        {
            if (_lastFilter == filter)
                return;

            _filter = filter;

            await ReloadAsync();
        }
        else
        {
            _firstRenderFilter = filter;
        }
    }

    private async Task ReloadAsync()
    {
        _isLoadRequested = true;

        if (_grid != null)
        {
            await _grid.ReloadServerData();
        }

        _isLoadRequested = false;

        _lastFilter = _filter;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if ((e.Key == "Enter" || e.Key == "NumpadEnter") && _grid != null)
        {
            await ReloadAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !String.IsNullOrEmpty(_firstRenderFilter))
        {
            await Load(_firstRenderFilter);
        }
    }

    private async Task<GridData<TSearchResult>> LoadGridData(GridState<TSearchResult> state, CancellationToken cancellationToken)
    {
        if (!_isLoadRequested)
            return new GridData<TSearchResult> { Items = new List<TSearchResult>() };

        var request = new PaginatedSearchRequest
        {
            PageIndex = 0,
            PageSize = _pageSize
        };

        if (!String.IsNullOrEmpty(_filter))
        {
            request.Filters.Add(_filter);
        }

        var result = await SearchService.PaginatedSearchAsync(request);

        var items = result?.Items?.ToList() ?? new List<TSearchResult>();
        _totalItems = result?.Count ?? 0;

        StateHasChanged();

        System.Diagnostics.Debug.WriteLine(items.Count);

        return new GridData<TSearchResult>
        {
            Items = items,
            TotalItems = _totalItems
        };
    }

    private async Task OnSelectedItemChangedAsync(TSearchResult? item)
    {
        if (item != null)
        {
            await OnItemSelected.InvokeAsync(item.DomainObjectId);
        }
    }

    private async Task OpenModuleInNewTab()
    {
        var workspaceKey = DomainObjectBrowserWorkspaceRegistry.Resolve<TDomainObject>();

        var url = $"/workspace/{workspaceKey}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}


