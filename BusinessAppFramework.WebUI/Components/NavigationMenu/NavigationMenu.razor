@using BusinessAppFramework.Application.Interfaces
@using Domain
@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor
@using WebUI.Interfaces

@inject ILocalizedStringService LocalizedStringService
@inject IWorkspaceNavigationService WorkspaceNavigationService
@inject IIconFactory IconFactory
@inject NavigationManager NavigationManager

@implements IDisposable

<style>
    .nav-menu-icon {
        width: 16px;
        height: 16px;
    }

    .nav-menu-button-text {
        color: white;
        font-size: 12px;
    }

    .module-text {
        font-size: 14px;
        color: #7A7E92;
    }

    .nav-item {
        cursor: pointer;
        border-radius: 4px;
        transition: background 0.15s ease;
    }

        .nav-item:hover {
            background: rgba(139, 128, 255, 0.08);
        }

    .module-header {
        border-radius: 4px;
        transition: background 0.15s ease;
    }

        .module-header:hover {
            background: rgba(139, 128, 255, 0.08);
        }

    .nav-skeleton {
        background-color: rgba(139, 128, 255, 0.08) !important;
    }
</style>

<MudNavMenu Color="Color.Dark">    

    @if (_isLoading)
    {
        <MudStack Spacing="0">
            @for (int i = 0; i < 8; i++)
            {
                <MudSkeleton Height="40px" Class="nav-skeleton mx-2" />
            }
        </MudStack>
    }
    else
    {
        @foreach (var moduleKey in _moduleKeys)
        {
            <div class="module-header" style="display: flex; align-items: center; justify-content: space-between; padding-right: 8px; cursor: pointer; height:40px;"
                 @onclick="() => ToggleModule(moduleKey)">
                <MudText Class="module-text" Style="padding-left:16px;">@LocalizedStringService.Get(moduleKey)</MudText>
                <MudIcon Icon="@(IsExpanded(moduleKey) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                         Style="color: #4A4D5E; width: 14px; height: 14px;" />
            </div>

            @if (IsExpanded(moduleKey))
            {
                @foreach (var workspaceKey in _workspaceKeys[moduleKey])
                {
                    var href = GetWorkspaceLink(workspaceKey);
                    var isActive = NavigationManager.Uri.Contains(href);

                    if (isActive)
                    {
                        <MudStack Row="true" Spacing="0" Style="background: color-mix(in srgb, var(--mud-palette-primary-darken) 20%, transparent);">
                            <div style="width: 3px; background: var(--mud-palette-primary-lighten); border-radius: 0 2px 2px 0;" />
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Style="padding-left:13px;">
                                <MudIcon Icon="@IconFactory.CreateIcon(workspaceKey)" Class="nav-menu-icon" Style="color:var(--mud-palette-primary-lighten)" />
                                <MudButton Href="@href"
                                           Style="text-transform: none;">
                                    <MudText Class="nav-menu-button-text" Style="color:var(--mud-palette-primary-lighten)">@LocalizedStringService.Get(workspaceKey)</MudText>
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Style="padding-left:16px;" Class="nav-item">
                            <MudIcon Icon="@IconFactory.CreateIcon(workspaceKey)" Class="nav-menu-icon" />
                            <MudButton Href="@href"
                                       FullWidth="true"
                                       Style="text-transform: none; justify-content: flex-start;">
                                <MudText Class="nav-menu-button-text">@LocalizedStringService.Get(workspaceKey)</MudText>
                            </MudButton>
                        </MudStack>
                    }
                }
            }
        }
    }


</MudNavMenu>

@code {
    private List<string> _moduleKeys { get; set; } = new()!;
    private Dictionary<string, List<string>> _workspaceKeys { get; set; } = new()!;
    private Dictionary<string, bool> _expandedModules = new();

    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _moduleKeys = await WorkspaceNavigationService.GetModuleKeysAsync();
        NavigationManager.LocationChanged += OnLocationChanged;

        foreach (var moduleKey in _moduleKeys)
        {
            _workspaceKeys[moduleKey] = await WorkspaceNavigationService.GetWorkspaceKeysAsync(moduleKey);
        }

        _isLoading = false;
    }

    private string GetWorkspaceLink(string workspaceKey) => "/workspace/" + workspaceKey;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private bool IsExpanded(string moduleKey)
        => _expandedModules.GetValueOrDefault(moduleKey, false);

    private void ToggleModule(string moduleKey)
        => _expandedModules[moduleKey] = !IsExpanded(moduleKey);

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
