@using System.Globalization
@using BusinessAppFramework.Application.Interfaces
@using Domain
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.Extensions.Localization
@using MudBlazor
@using WebUI.Interfaces

@inject ILocalizedStringService LocalizedStringService
@inject IWorkspaceNavigationService WorkspaceNavigationService
@inject IIconFactory IconFactory
@inject NavigationManager NavigationManager

@implements IDisposable

<style>
    .mud-icon-button .mud-icon-root {
        width: 22px;
        height: 22px;
    }

    .mud-icon-button.active-nav {
        color: #33EA51 !important;
    }

        .mud-icon-button.active-nav .mud-icon-root {
            color: #33EA51 !important;
        }
</style>

<MudNavMenu Color="Color.Dark">

    @if (_moduleKeys != null)
    {
        <MudStack Spacing="0">

            @{
                var homeRef = NavigationManager.BaseUri;
                var isHomeActive = NavigationManager.Uri.Equals(homeRef, StringComparison.OrdinalIgnoreCase);

                <MudTooltip Text="@LocalizedStringService.Get("")" Delay="300" Placement="Placement.Right">
                    <MudIconButton Href="@homeRef"
                                   Icon="@Icons.Material.Outlined.Home"
                                   Color="Color.Inherit"
                                   Class="@(isHomeActive ? "active-nav" : "")" />
                </MudTooltip>
            }

            @foreach (var moduleKey in _moduleKeys)
            {
                var href = GetModuleWorkspaceLink(moduleKey);
                var isActive = NavigationManager.Uri.Contains(href);

                <MudTooltip Text="@LocalizedStringService.Get(moduleKey)" Delay="700" Placement="Placement.Right">
                    <MudIconButton Href="@href"
                                   Icon="@IconFactory.CreateIcon(StringKey.From(moduleKey))"
                                   Color="Color.Inherit"
                                   Class="@(isActive ? "active-nav" : "")" />
                </MudTooltip>
            }
        </MudStack>
    }

</MudNavMenu>

@code {

    private List<string> _moduleKeys { get; set; } = new()!;

    protected override async Task OnInitializedAsync()
    {
        _moduleKeys = await WorkspaceNavigationService.GetModuleKeysAsync();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    string GetModuleWorkspaceLink(string key) => "/module/" + key;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
