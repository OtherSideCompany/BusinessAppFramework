@using BusinessAppFramework.Application.Interfaces
@using BusinessAppFramework.Contracts
@using MudBlazor

@typeparam TEnum where TEnum : struct, Enum

@inject ILocalizedStringService LocalizedStringService

<MudSelect T="TEnum"
           Margin="Margin.Dense"
           Typo="Typo.body2"
           Value="@Value"
           ValueChanged="@OnValueChangedInternal"
           ReadOnly="@ReadOnly"
           Variant="Variant.Outlined">
    @foreach (var enumValue in EnumValues)
    {
        <MudSelectItem T="TEnum" Value="@enumValue">
            @LocalizedStringService.Get(EnumKeys<TEnum>.For(enumValue))
        </MudSelectItem>
    }
</MudSelect>

@code {
    [CascadingParameter] public Func<Task>? NotifyItemChanged { get; set; }
    [Parameter] public TEnum Value { get; set; }
    [Parameter] public EventCallback<TEnum> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    private static readonly IReadOnlyList<TEnum> EnumValues = Enum.GetValues<TEnum>().ToList();

    private async Task OnValueChangedInternal(TEnum v)
    {
        Value = v;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(v);

        if (NotifyItemChanged != null)
            await NotifyItemChanged();
    }
}
