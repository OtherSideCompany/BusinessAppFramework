@using BusinessAppFramework.WebUI.Components.Editor
@using BusinessAppFramework.WebUI.Interfaces
@using Contracts
@using Domain.DomainObjects
@using MudBlazor

@typeparam TItem where TItem : DomainObject, new()

@inherits DomainObjectBranchEditor<TItem>

@inject IIconFactory IconFactory

<MudStack Spacing="2">

    <MudStack AlignItems="AlignItems.Center" Row="true" Spacing="2">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@IconFactory.CreateIcon(DomainObjectAggregateKeys<TItem>.Type)" Size="Size.Small" />
            <MudText Typo="Typo.h6">@LocalizedStringService.Get(DomainObjectAggregateKeys<TItem>.Type)</MudText>
        </MudStack>

        <MudStack Row="true" Justify="Justify.FlexStart" Spacing="0">

            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           OnClick="CreateItemAsync"
                           Color="@Color.Primary"
                           Size="Size.Small"
                           Variant="Variant.Text"
                           Style="font-weight: normal;">
            </MudIconButton>

            @ToolBarActions

        </MudStack>

    </MudStack>

    <CascadingValue Value="(Func<Task>)NotifyItemChanged">

        <MudDataGrid T="TItem"
                     EditMode="DataGridEditMode.Cell"
                     EditTrigger="DataGridEditTrigger.OnRowClick"
                     Items="@Items"
                     SortMode="@SortMode.None"
                     ReadOnly="false"
                     Bordered="true"
                     Dense="true"
                     ColumnResizeMode="ResizeMode.Column"
                     Elevation="0"
                     Class="osc-datagrid"
                     Virtualize="false"
                     CommittedItemChanges="OnCommitedItemChanged">
            <Columns>
                @ColumnsContent
                <TemplateColumn T="TItem" Title="@LocalizedStringService.Get(StringKeys.ActionsKey)">
                    <EditTemplate>
                        <MudStack Row="true" Spacing="0">
                            @ItemActions?.Invoke(context.Item)
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="async () => await DeleteItemAsync(context.Item)" />
                        </MudStack>
                    </EditTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

    </CascadingValue>

</MudStack>

@code {
    [Parameter] public RenderFragment? ToolBarActions { get; set; }
    [Parameter] public RenderFragment? ColumnsContent { get; set; }
    [Parameter] public RenderFragment<TItem>? ItemActions { get; set; }
}