@using Application.Search
@using Application.Trees
@using BusinessAppFramework.Application.Actions
@using BusinessAppFramework.Application.Interfaces
@using BusinessAppFramework.WebUI.Components.Dialog
@using Domain.DomainObjects
@using MudBlazor
@using WebUI.Interfaces

@inject ITreeGateway TreeGateway
@inject IDomainObjectServiceGateway<TDomainObject> DomainObjectServiceGateway
@inject ISearchGateway<TSearchResult> SearchGateway
@inject IDialogService DialogService

@typeparam TDomainObject where TDomainObject : DomainObject, new()
@typeparam TSearchResult where TSearchResult : DomainObjectSearchResult, new()

<style>
    .osc-tile-icon-circle {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-primary);
    }

    .osc-tile {
        cursor: pointer;
        border: 1px solid var(--mud-palette-divider);
        border-radius: 8px;
    }

        .osc-tile:hover {
            border-color: var(--mud-palette-primary) !important;
            background: var(--mud-palette-background-gray) !important;
        }
</style>

<MudCard Class="pa-2 osc-tile" Elevation="0" Outlined="false">

    <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">

        <MudCardContent Class="pa-1">

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">

                <MudPaper Class="osc-tile-icon-circle" Elevation="0">
                    <MudIcon Icon="@Icon" Style="color:var(--mud-palette-white) !important;" Size="Size.Small" />
                </MudPaper>

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Class="fw-600">
                        @Node?.Summary?.Title
                    </MudText>

                    <MudText Typo="Typo.body2">
                        @Node?.Summary?.SubTitle
                    </MudText>

                </MudStack>

            </MudStack>

        </MudCardContent>

        <MudStack Spacing="0" Row="true" Justify="Justify.FlexEnd">

            <MudIconButton OnClick="EditAsync"
                           Icon="@Icons.Material.Outlined.Edit"
                           Size="Size.Small" />

            <MudIconButton OnClick="RequestDeleteAsync"
                           Icon="@Icons.Material.Outlined.Delete"
                           Size="Size.Small"
                           Color="@Color.Error" />

        </MudStack>

    </MudStack>    

</MudCard>

@code {
    [Parameter] public Node? Node { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public EventCallback<Node?> OnDeleteRequested { get; set; }

    private async Task RequestDeleteAsync()
    {
        await OnDeleteRequested.InvokeAsync(Node);
    }

    private async Task EditAsync()
    {
        if (Node == null)
            return;

        var editedObject = await DomainObjectServiceGateway.GetHydratedAsync(Node.Id);

        if (editedObject == null)
            return;

        var parameters = new DialogParameters<DomainObjectDialogEditor<TDomainObject>>
        {
            { x => x.Target, editedObject }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large, 
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<DomainObjectDialogEditor<TDomainObject>>("Éditer", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await DomainObjectServiceGateway.SaveAsync(editedObject);
            Node.Summary = await SearchGateway.GetNodeSummaryAsync(Node.Id);
        }
    }
}
