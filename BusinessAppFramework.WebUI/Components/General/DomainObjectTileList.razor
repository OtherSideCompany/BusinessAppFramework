@using Application.Interfaces
@using Application.Search
@using Application.Services
@using Application.Trees
@using Contracts
@using Domain
@using Domain.DomainObjects
@using MudBlazor
@using WebUI.Interfaces

@inject ITreeGateway TreeGateway
@inject IIconFactory IconFactory
@inject IUserDialogService UserDialogService
@inject ILocalizedStringService LocalizedStringService

@typeparam TDomainObject where TDomainObject : DomainObject, new()
@typeparam TSearchResult where TSearchResult : DomainObjectSearchResult, new()

@if (Branch != null)
{
    <MudStack Justify="Justify.FlexStart" AlignItems="AlignItems.Start" Spacing="2">
    
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   OnClick="CreateAsync"
                   Size="Size.Small"
                   Variant="Variant.Text"
                   IconColor="@Color.Primary"
                   Style="font-weight: normal;">
                   @LocalizedStringService.Get(Contracts.ActionKeys.CreateActionKey)
        </MudButton>

        <MudGrid Spacing="2">

            @foreach (var node in Branch.Nodes)
            {
                <MudItem xs="3">
                    <DomainObjectTile TDomainObject="TDomainObject"
                                      TSearchResult="TSearchResult"
                                      Node="node"
                                      Icon="@IconFactory.CreateIcon(StringKey.From(Branch?.ParentChildRelationKey))"
                                      OnDeleteRequested="DeleteAsync" />
                </MudItem>
            }

        </MudGrid>

    </MudStack>
}


@code {
    [Parameter] public string? TilesIcon { get; set; }
    [Parameter] public int? ParentId { get; set; }
    [Parameter] public Branch? Branch { get; set; }

    protected async virtual Task CreateAsync()
    {
        if (ParentId == null || Branch == null)
        {
            return;
        }

        var node = await TreeGateway.CreateNode(ParentId.Value, Branch.ParentChildRelationKey);

        if (node != null)
        {
            Branch.AddNode(node);
        }
    }    

    private async Task DeleteAsync(Node? node)
    {
        if (node != null && ParentId != null && Branch != null)
        {
            if (await UserDialogService.ConfirmAsync(LocalizedStringService.Get(MessageKeys.DeleteConfirmationMessage) ?? "delete_msg"))
            {
                if (await TreeGateway.DeleteNodeAsync(ParentId.Value, node.Id, Branch.ParentChildRelationKey))
                {
                    Branch?.RemoveNode(node.Id);
                }
            }
        }
    }
}
