@using BusinessAppFramework.Application.Factories
@using BusinessAppFramework.Application.Interfaces
@using BusinessAppFramework.Domain
@using MudBlazor

@inject IDomainObjectNavigationApplicationActionFactory DomainObjectNavigationApplicationActionFactory

<MudLink Href="@_pageNavigationAction?.BuildRoute(DomainObjectId)">
    @Text
</MudLink>

@code {
    [Parameter, EditorRequired] public int DomainObjectId { get; set; }
    [Parameter, EditorRequired] public string Text { get; set; }
    [Parameter, EditorRequired] public string NavigationApplicationActionKey { get; set; }

    private IDomainObjectNavigationApplicationAction? _pageNavigationAction;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _pageNavigationAction = DomainObjectNavigationApplicationActionFactory.Get(NavigationApplicationActionKey);
    }
}
