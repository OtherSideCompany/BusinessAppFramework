@using System.Reflection
@using BusinessAppFramework.Application.Interfaces
@using Application.Relations
@using Domain.Attributes
@using MudBlazor
@using WebUI.Interfaces

@inject ILocalizedStringService LocalizedStringService
@inject IDialogService DialogService
@inject IWorkspaceDescriptorFactory WorkspaceDescriptorFactory
@inject IReferenceResolver RelationResolver
@inject IRelationSelectorRegistry RelationSelectorRegistry

@if (Target != null)
{
    var props = GetEditableProperties().ToList();

    <MudStack Spacing="6">
        @foreach (var category in GetCategoriesOrDefault())
        {
            <MudStack Spacing="3">

                @if (DisplayCategoryHeaders)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@category.Icon" Size="Size.Small" />
                        <MudText Typo="Typo.h6">@LocalizedStringService.Get(category.LabelKey)</MudText>
                    </MudStack>

                    <MudDivider />
                }

                <MudGrid Spacing="2">
                    @foreach (var propEdition in category.PropertyEditions)
                    {
                        var prop = props.FirstOrDefault(p => p.Name == propEdition.PropertyName);
                        if (prop != null)
                        {
                            var label = LocalizedStringService.ResolveProperty(Target.GetType(), prop.Name);
                            var concreteProperty = Target.GetType().GetProperty(prop.Name, BindingFlags.Public | BindingFlags.Instance);
                            var value = concreteProperty?.GetValue(Target);
                            <MudItem xs="12" md="@propEdition.Md">
                                <ObjectProperty PropertyInfo="@prop"
                                                PropertyValue="@value"
                                                Target="@Target"
                                                OnChanged="async(PropertyInfo p) => await OnChanged.InvokeAsync(p)" />
                            </MudItem>
                        }
                    }

                </MudGrid>

                    
            </MudStack>
        }

    </MudStack>

}

@code {
    [Parameter] public object? Target { get; set; }
    [Parameter] public EventCallback<PropertyInfo> OnChanged { get; set; }
    [Parameter] public List<PropertyCategory> PropertyCategories { get; set; } = new();
    [Parameter] public bool DisplayCategoryHeaders { get; set; } = true;

    private PropertyCategory _uncategorizedPropertyCategory = new PropertyCategory()
    {
        LabelKey = BusinessAppFramework.Contracts.StringKeys.OthersKey,
        Icon = Icons.Material.Outlined.MoreHoriz
    };

    public void Refresh() => StateHasChanged();

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _uncategorizedPropertyCategory.PropertyEditions = _uncategorizedProperties.Select(p => new PropertyEdition() { PropertyName = p.Name }).ToList();
    }

    private List<PropertyInfo> _uncategorizedProperties => GetEditableProperties()
        .Where(p => !PropertyCategories.Any(c => c.PropertyEditions.Any(e => e.PropertyName == p.Name)))
        .ToList();

    private List<PropertyCategory> GetDefaultCategory()
    {
        var propertyCategory = new PropertyCategory()
        {
            LabelKey = BusinessAppFramework.Contracts.StringKeys.GeneralKey,
            Icon = Icons.Material.Outlined.Info
        };

        propertyCategory.PropertyEditions = GetEditableProperties().Select(p => new PropertyEdition() { PropertyName = p.Name }).ToList();

        return new List<PropertyCategory> { propertyCategory };
    }

    private List<PropertyCategory> GetCategoriesOrDefault()
    {
        List<PropertyCategory> categories;

        if (PropertyCategories.Any())
        {
            categories = PropertyCategories;

            if (_uncategorizedPropertyCategory.PropertyEditions.Any())
            {
                categories.Add(_uncategorizedPropertyCategory);
            }
        }
        else
        {
            categories = GetDefaultCategory();
        }

        return categories;
    }

    private IEnumerable<PropertyInfo> GetEditableProperties()
    {
        if (Target == null)
            return new List<PropertyInfo>();

        return Target.GetType()
            .GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(p => p.CanRead && p.CanWrite)
            .Where(p => !IsSystemProperty(p))
            .OrderBy(p => GetInheritanceDepth(p.DeclaringType))
            .ThenBy(p => p.MetadataToken);
    }

    private bool IsSystemProperty(PropertyInfo prop)
    {
        var declaringProp = prop.DeclaringType?.GetProperty(prop.Name, BindingFlags.Public | BindingFlags.Instance);
        return declaringProp?.IsDefined(typeof(SystemPropertyAttribute), false) == true;
    }

    private int GetInheritanceDepth(Type? type)
    {
        if (type == null) return int.MaxValue;
        int depth = 0;
        var current = type;
        while (current.BaseType != null) { depth++; current = current.BaseType; }
        return depth;
    }
}