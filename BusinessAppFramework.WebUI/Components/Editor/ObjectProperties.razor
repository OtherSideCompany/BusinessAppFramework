@using System.Reflection
@using BusinessAppFramework.Application.Interfaces
@using Application.Relations
@using Domain.Attributes
@using Domain.DomainObjects
@using MudBlazor
@using Domain
@using WebUI.Components.Browser
@using WebUI.Components.Pages
@using WebUI.Interfaces

@inject ILocalizedStringService LocalizedStringService
@inject IDialogService DialogService
@inject IWorkspaceDescriptorFactory WorkspaceDescriptorFactory
@inject IRelationResolver RelationResolver
@inject IRelationSelectorRegistry RelationSelectorRegistry

<MudGrid Spacing="2">
    @if (Target != null)
    {
        var props = GetEditableProperties().ToList();

        for (int i = 0; i < props.Count; i++)
        {
            var prop = props[i];
            var propKey = $"{prop.DeclaringType?.Name}_{prop.Name}";
            var label = LocalizedStringService.Get(propKey);
            var concreteProperty = Target.GetType().GetProperty(prop.Name, BindingFlags.Public | BindingFlags.Instance);
            var value = concreteProperty?.GetValue(Target);

            if (Columns == 1)
            {
                <MudItem xs="@_labelXs" Class="d-flex align-center">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@label</MudText>
                </MudItem>

                <MudItem xs="@_valueXs">

                    <ObjectProperty PropertyInfo="@prop"
                                    PropertyValue="@value"
                                    Target="@Target"
                                    OnChanged="async() => await OnChanged.InvokeAsync()" />
                </MudItem>
            }
            else
            {
                <MudItem xs="@_valueXs">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@label</MudText>

                    <ObjectProperty PropertyInfo="@prop"
                                    PropertyValue="@value"
                                    Target="@Target"
                                    OnChanged="async() => await OnChanged.InvokeAsync()" />
                </MudItem>
            }                      
        }
    }
</MudGrid>

    @code {
    [CascadingParameter] public object? Target { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public int Columns { get; set; } = 1;

    private int _labelXs = 4;
    private int _valueXs = 8;

    public void Refresh()
    {
        StateHasChanged();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (Columns == 1)
        {
            _labelXs = 4;
            _valueXs = 8;
        }
        else 
        {
            _labelXs = 0;
            _valueXs = 12 / Columns;
        }
    }

    private IEnumerable<PropertyInfo> GetEditableProperties()
    {
        if (Target == null)
            return new List<PropertyInfo>();

        return Target.GetType()
            .GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(p => p.CanRead && p.CanWrite)
            .Where(p => !IsSystemProperty(p))
            .OrderBy(p => GetInheritanceDepth(p.DeclaringType))
            .ThenBy(p => p.MetadataToken);
    }

    private bool IsSystemProperty(PropertyInfo prop)
    {
        var declaringProp = prop.DeclaringType?.GetProperty(prop.Name, BindingFlags.Public | BindingFlags.Instance);
        return declaringProp?.IsDefined(typeof(SystemPropertyAttribute), false) == true;
    }

    private int GetInheritanceDepth(Type? type)
    {
        if (type == null) return int.MaxValue;

        int depth = 0;
        var current = type;

        while (current.BaseType != null)
        {
            depth++;
            current = current.BaseType;
        }

        return depth;
    }
}
