@using BusinessAppFramework.Application.Interfaces
@using Contracts
@using Domain.DomainObjects
@using MudBlazor

@inject ILocalizedStringService LocalizedStringService

@if (Dense)
{
    <div style="position: relative; display: inline-block;">
        <MudIconButton Icon="@Icons.Material.Outlined.Info"
                       Size="Size.Small"
                       Style="color: var(--mud-palette-text-secondary);"
                       OnClick="@(() => _open = !_open)" />

        <MudPopover Open="_open"
                    AnchorOrigin="Origin.BottomLeft"
                    TransformOrigin="Origin.TopRight"
                    Paper="true"
                    Style="padding: 12px 16px; max-width: 320px; margin-top: 4px;">
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                @DisplayString
            </MudText>
        </MudPopover>
    </div>

    <MudOverlay Visible="_open"
                OnClick="@(() => _open = false)"
                AutoClose="true" />
}
else
{
    <MudText Typo="Typo.caption" Align="Align.Start" Style="color:gray; font-style: italic">@DisplayString</MudText>
}

@code {
    [CascadingParameter] public DomainObject? DomainObject { get; set; }
    [Parameter] public bool Dense { get; set; }
    private bool _open = false;

    public string CreatedInfo =>
        DomainObject == null
            ? ""
            : $"{DomainObject.CreationDate:dd/MM/yyyy HH:mm} {LocalizedStringService.Get(StringKeys.ByKey)} {DomainObject.CreatedByName}";

    public string ModifiedInfo =>
        DomainObject?.LastModifiedDateTime == null
            ? ""
            : $"{DomainObject.LastModifiedDateTime:dd/MM/yyyy HH:mm} {LocalizedStringService.Get(StringKeys.ByKey)} {DomainObject.LastModifiedByName}";

    public string DisplayString => $"{LocalizedStringService.Get(StringKeys.CreationKey)} : {CreatedInfo}, {LocalizedStringService.Get(StringKeys.LastModificationKey)?.ToLower()} : {ModifiedInfo}";
}
