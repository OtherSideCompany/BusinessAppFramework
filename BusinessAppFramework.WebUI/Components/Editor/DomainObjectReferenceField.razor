@using Application.Descriptors
@using Application.Relations
@using BusinessAppFramework.Application.Interfaces
@using BusinessAppFramework.Application.Search
@using BusinessAppFramework.WebUI.Components.SearchList
@using Domain.DomainObjects
@using Microsoft.Extensions.DependencyInjection
@using MudBlazor
@using WebUI.Components.Selector
@using WebUI.Interfaces

@inject IReferenceResolver RelationResolver
@inject ILocalizedStringService LocalizedStringService
@inject IWorkspaceDescriptorFactory WorkspaceDescriptorFactory
@inject IRelationSelectorRegistry RelationSelectorRegistry
@inject IServiceProvider ServiceProvider
@inject IDialogService DialogService
@inject IReferenceNavigationKeyRegistry ReferenceNavigationKeyRegistry

<style>
    .mud-icon-button-size-small .mud-icon-root {
        font-size: 16px;
        width: 16px;
        height: 16px;
    }

    .lookup-field,
    .lookup-field .mud-input-slot,
    .lookup-field .mud-input-adornment {
        cursor: pointer;
    }
</style>

@if (_selectedResult is not null)
{
    var navigationKey = ReferenceNavigationKeyRegistry.TryGetNavigationKey(DomainObjectReference?.RelationKey ?? "");

    <MudField Typo="Typo.body2"
              Variant="@Variant"
              Margin="Margin.Dense"
              AdornmentIcon="@Icons.Material.Outlined.Search"
              Adornment="Adornment.End"
              Class="lookup-field"
              InnerPadding="false">

        <div style="margin-bottom:4px;">
            @if (!string.IsNullOrEmpty(_selectedResult?.DisplayValue))
            {
                var navigationKey = ReferenceNavigationKeyRegistry.TryGetNavigationKey(DomainObjectReference?.RelationKey ?? "");

                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    @if (!String.IsNullOrEmpty(navigationKey))
                    {

                        <NavigationLink NavigationApplicationActionKey="@navigationKey"
                                        DomainObjectId="@_id"
                                        Text="@_selectedResult.DisplayValue" />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">@_selectedResult.DisplayValue</MudText>
                    }
                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                   OnClick="ClearSelectionAsync" />
                </MudStack>
            }
            else
            {
                <MudText Style="color: var(--mud-palette-text-disabled);">
                    @LocalizedStringService.Get(BusinessAppFramework.Contracts.StringKeys.SelectToSearchKey)
                </MudText>
            }
        </div>

    </MudField>
}
else
{
    <MudAutocomplete T="DomainObjectSearchResult"
                     Variant="@Variant"
                     Margin="Margin.Dense"
                     Value="@_selectedResult"
                     ValueChanged="OnResultSelected"
                     SearchFunc="SearchAsync"
                     ToStringFunc="@(r => r?.DisplayValue ?? string.Empty)"
                     ResetValueOnEmptyText="false"
                     AdornmentIcon="@Icons.Material.Outlined.Search"
                     Adornment="Adornment.End"
                     OnAdornmentClick="OpenSelector"
                     Placeholder="@LocalizedStringService.Get(BusinessAppFramework.Contracts.StringKeys.TypeToSearchKey)">
        <MoreItemsTemplate>
            <MudButton FullWidth="true"
                       StartIcon="@Icons.Material.Outlined.Search"
                       OnClick="OpenSelector">
                @LocalizedStringService.Get(BusinessAppFramework.Contracts.StringKeys.SearchKey)
            </MudButton>
        </MoreItemsTemplate>
        <NoItemsTemplate>
            <MudStack>
                <MudButton FullWidth="true"
                           StartIcon="@Icons.Material.Outlined.Search"
                           OnClick="OpenSelector">
                    @LocalizedStringService.Get(BusinessAppFramework.Contracts.StringKeys.SearchKey)
                </MudButton>
                @* <MudButton FullWidth="true"
                           StartIcon="@Icons.Material.Outlined.Add"
                           OnClick="CreateNewAsync">
                    @LocalizedStringService.Get(StringKeys.CreateNewKey)
                </MudButton> *@
            </MudStack>
        </NoItemsTemplate>
    </MudAutocomplete>
}

@code {
    [Parameter]
    public DomainObjectReference? DomainObjectReference
    {
        get => _domainObjectReference;
        set
        {
            if (_domainObjectReference?.DomainObjectId == value?.DomainObjectId && _domainObjectReference?.RelationKey == value?.RelationKey)
                return;

            _domainObjectReference = value;
            HandleDomainObjectReferenceChanged();
        }
    }
    [Parameter] public string Label { get; set; } = default!;
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public EventCallback<DomainObjectReference?> OnDomainObjectReferenceChanged { get; set; }

    private int _id => DomainObjectReference?.DomainObjectId == null ? 0 : DomainObjectReference.DomainObjectId.Value;

    private DomainObjectReference? _domainObjectReference;
    private IDomainObjectSelectorDescriptor? _domainObjectSelectorDescriptor;

    private DomainObjectSearchResult? _selectedResult;

    private async Task OpenSelector()
    {
        if (_domainObjectSelectorDescriptor == null)
            return;

        var parameters = new DialogParameters
        {
            { nameof(SelectorDialog.Descriptor), _domainObjectSelectorDescriptor }
        };

        var options = new DialogOptions
        {
            BackdropClick = true,
            NoHeader = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<SelectorDialog>(string.Empty, parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var selectedId = (int)result.Data;
            await OnItemSelected(selectedId, false);
        }
    }

    private async Task OnItemSelected(int itemId, bool init)
    {
        if (DomainObjectReference == null)
            return;

        DomainObjectReference.DomainObjectId = itemId;

        if (RelationResolver.TryGetReferenceRelationEntry(DomainObjectReference.RelationKey, out var relationEntry))
        {
            var gatewayType = typeof(IDomainObjectServiceGateway<>).MakeGenericType(relationEntry.TargetDomainObjectType);
            dynamic gateway = ServiceProvider.GetRequiredService(gatewayType);
            var hydrated = await gateway.GetHydratedDomainObjectReference(itemId, DomainObjectReference.RelationKey);
            DomainObjectReference.DisplayValue = hydrated.DisplayValue;
        }

        _selectedResult = new DomainObjectSearchResult
        {
            DomainObjectId = itemId,
            DisplayValue = DomainObjectReference.DisplayValue
        };

        if (!init)
            await OnDomainObjectReferenceChanged.InvokeAsync(DomainObjectReference);

        StateHasChanged();
    }

    private async Task ClearSelectionAsync()
    {
        _selectedResult = null;

        if (DomainObjectReference is not null)
        {
            DomainObjectReference.DomainObjectId = null;
            DomainObjectReference.DisplayValue = null;
        }

        await OnDomainObjectReferenceChanged.InvokeAsync(DomainObjectReference);
        StateHasChanged();
    }

    private async Task HandleDomainObjectReferenceChanged()
    {
        if (DomainObjectReference == null)
            return;

        if (DomainObjectReference.DomainObjectId is int id)
            await OnItemSelected(id, true);
        else
            _selectedResult = null;

        var selectorWorkspaceKey = RelationSelectorRegistry.Resolve(DomainObjectReference.RelationKey);
        _domainObjectSelectorDescriptor = (IDomainObjectSelectorDescriptor)WorkspaceDescriptorFactory.GetWorkspaceDescriptor(selectorWorkspaceKey);
    }

    private async Task OnResultSelected(DomainObjectSearchResult? result)
    {
        _selectedResult = result;

        if (result != null)
        {
            await OnItemSelected(result.DomainObjectId, false);
        }
        else
        {
            await ClearSelectionAsync();
        }
    }

    private async Task<IEnumerable<DomainObjectSearchResult>> SearchAsync(string searchText, CancellationToken token)
    {
        if (_domainObjectSelectorDescriptor is null)
            return [];

        var gatewayType = typeof(ISearchGateway<>).MakeGenericType(_domainObjectSelectorDescriptor.SearchResultType);
        var searchGateway = (ISearchGatewayBase)ServiceProvider.GetRequiredService(gatewayType);

        var paginatedSearchRequest = new PaginatedSearchRequest
        {
            PageIndex = 0,
            PageSize = 10
        };

        if (!String.IsNullOrEmpty(searchText))
        {
            paginatedSearchRequest.Filters.Add(searchText);
        }

        var result = await searchGateway.PaginatedSearchDomainObjectsAsync(paginatedSearchRequest);

        return result.Items;
    }
}
