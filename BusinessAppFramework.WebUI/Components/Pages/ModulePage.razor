@page "/module/{ModuleKey}"

@using BusinessAppFramework.Application.Interfaces
@using Domain
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@using MudBlazor
@using WebUI.Interfaces

@attribute [Authorize]

@inject ILocalizedStringService LocalizedStringService
@inject IWorkspaceNavigationService WorkspaceNavigationService
@inject IIconFactory IconFactory
@inject NavigationManager NavigationManager

<style>

    .paper-header {
        border-radius: 0;
        height:48px;
        background: var(--mud-palette-background);
        border-bottom: 1px solid var(--mud-palette-divider);
    }

</style>

<MudPaper Class="paper-header" Outlined="false" Elevation="0">
    <MudStack AlignItems="AlignItems.Center" Row="true" Justify="Justify.Center" Style="height:100%;">

        @foreach (var key in _workspaceKeys)
        {
            var isActive = key == _activeWorkspaceKey;
            <MudTooltip Text="@LocalizedStringService.Get(key)" Placement="Placement.Bottom">
                <MudIconButton Icon="@IconFactory.CreateIcon(StringKey.From(key))"
                               Size="Size.Small"
                               OnClick="() => OnWorkspaceChanged(key)"
                               Style="@(isActive ? "color: var(--mud-palette-primary) !important; width: 36px; height: 36px;" :
                                                   "color: var(--mud-palette-text-secondary) !important; width: 36px; height: 36px;")" />
            </MudTooltip>
        }

    </MudStack>
</MudPaper>

@if (_activeWorkspaceKey != null)
{
    <WorkspaceView WorkspaceKey="@_activeWorkspaceKey" />
}

@code {
    [Parameter] public string ModuleKey { get; set; } = "";
    [Parameter][SupplyParameterFromQuery(Name = "workspace")] public string? QueryWorkspaceKey { get; set; }

    private List<string> _workspaceKeys = new()!;
    private string? _activeWorkspaceKey;
    private string? _loadedModuleKey;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedModuleKey != ModuleKey)
        {
            _loadedModuleKey = ModuleKey;
            _workspaceKeys = await WorkspaceNavigationService.GetWorkspaceKeysAsync(ModuleKey);
            _activeWorkspaceKey = null;
        }

        if (!string.IsNullOrWhiteSpace(QueryWorkspaceKey) && _workspaceKeys.Contains(QueryWorkspaceKey))
        {
            _activeWorkspaceKey = QueryWorkspaceKey;
        }
        else if (_activeWorkspaceKey is null || !_workspaceKeys.Contains(_activeWorkspaceKey))
            _activeWorkspaceKey = _workspaceKeys.FirstOrDefault();
    }

    private Task OnWorkspaceChanged(string key)
    {
        _activeWorkspaceKey = key;

        var uri = NavigationManager.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["workspace"] = key,
            ["search"] = null,
            ["constraint"] = null,
            ["page"] = null
        });

        NavigationManager.NavigateTo(uri);

        return Task.CompletedTask;
    }
}
