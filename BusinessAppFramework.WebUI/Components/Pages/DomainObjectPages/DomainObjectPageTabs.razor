@using MudBlazor

<style>
    .tab-panel {
        background-color: var(--mud-palette-surface);
        padding: 20px;
    }

    .compact-tabs .mud-tabs-toolbar {
        min-height: 40px;
    }

    .compact-tabs .mud-tabs-panels {
        border-top: 1px solid var(--mud-palette-lines-default);
        margin-top: -8px;
    }

    .compact-tabs .mud-tab {
        min-height: 40px;
        font-weight: 400;
        text-transform: none;
        font-size: 12px;
        letter-spacing: normal;
        color: var(--mud-palette-text-secondary);
    }

        .compact-tabs .mud-tab.mud-tab-active {
            color: black;
            font-weight: 500;
        }

    .compact-tabs .mud-badge {
        background-color: var(--mud-palette-background) !important;
        border-width:1px;
        border-color: var(--mud-palette-divider) !important;
        color: var(--mud-palette-text-primary) !important;
        transform: scale(0.9);
    }
</style>

<MudPaper Elevation="0"
          Outlined="true"
          Style="height: 100% !important;">

    <MudTabs Elevation="0"
             Rounded="true"
             ApplyEffectsToContainer="true"
             TabPanelsClass="tab-panel"
             Class="compact-tabs">
        @ChildContent
    </MudTabs>

</MudPaper>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
