@using BusinessAppFramework.Contracts
@using BusinessAppFramework.WebUI.Components.Browser
@using MudBlazor
@using BusinessAppFramework.Domain.DomainObjects
@using BusinessAppFramework.WebUI.Components.Pages.DomainObjectPages
@using BusinessAppFramework.WebUI.Components.Editor

@typeparam T where T : DomainObject, new()

@inherits DomainObjectPageBase<T>

<DomainObjectPageLayout IsDeleted="_isDeleted"
                        IsDirty="IsDirty"
                        OnSave="SaveAsync"
                        OnUndo="UndoAsync">
    <ChildContent>
    <MudStack Spacing="0">

        <DomainObjectPageHeaderTitle DomainObject="@DomainObject" DescriptorKey="@Descriptor.WorkspaceKey">
            <Actions>
                <ActionButton OnClick="() => DeleteAsync()"
                              ActionKey="@ActionKeys.DeleteActionKey" />
            </Actions>
        </DomainObjectPageHeaderTitle>

        <DomainObjectPageTabs>

            <MudTabPanel Text="@LocalizedStringService.Get(BusinessAppFramework.Contracts.StringKeys.InfosKey)">
                <ObjectProperties OnChanged="() => MarkDirty()" Target="@DomainObject" />
            </MudTabPanel>

        </DomainObjectPageTabs>

    </MudStack>
    </ChildContent>

    <RightPanelContent>
        <MudStack Spacing="8">

            <MudStack Spacing="4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Outlined.History" Size="Size.Small" />
                    <MudText Typo="Typo.h6">@LocalizedStringService.Get(BusinessAppFramework.Contracts.StringKeys.HistoryKey)</MudText>
                </MudStack>

                <DomainObjectHistory DomainObject="@DomainObject" />
            </MudStack>

        </MudStack>
    </RightPanelContent>
</DomainObjectPageLayout>

@code {

}

