<style>
    .osc-domainobject-page {
        height: 100%;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: var(--mud-palette-background);
    }

    .osc-page-content {
        flex: 1 1 auto;
        overflow-y: auto;
        min-height: 0;
        padding:16px;
    }
</style>

@if (IsDeleted)
{
    <DeletedDomainObjectPage />
}
else
{
    <div class="osc-domainobject-page">
        <div class="osc-page-content">
            @ChildContent
        </div>
    </div>

    <ChangesPopover IsDirty="IsDirty"
                    SaveAsync="OnSave"
                    UndoAsync="OnUndo" />
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool IsDeleted { get; set; }
    [Parameter] public bool IsDirty { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnUndo { get; set; }
}