@using BusinessAppFramework.Application.Actions
@using BusinessAppFramework.Application.Interfaces
@using Application.Workflows
@using BusinessAppFramework.Domain
@using BusinessAppFramework.WebUI.Components.Browser
@using BusinessAppFramework.WebUI.Components.SearchList
@using BusinessAppFramework.WebUI.Interfaces
@using MudBlazor
@using Transition = Application.Workflows.Transition

@inject ILocalizedStringService LocalizedStringService
@inject IApplicationActionExecutionService ApplicationActionExecutionService
@inject IWorkflowServiceGateway WorkflowServiceGateway
@inject IUserDialogService UserDialogService

<style>
    .wf-step {
        flex: 1;
        padding: 8px;
        transition: border-color 0.15s ease;
        border-radius: 12px;
    }

    .wf-step-completed {
        background-color: var(--mud-palette-success-hover) !important;
        border-color: var(--mud-palette-primary) !important;
        color: var(--mud-palette-success-darken) !important;
    }

    .wf-step-active {
        background-color: var(--mud-palette-secondary-hover) !important;
        border-color: var(--mud-palette-secondary-info) !important;
        border-width: 2px !important;
        padding: 7px !important;
        color: var(--mud-palette-secondary-darken) !important;
    }

    .wf-step-pending {
        background-color: var(--mud-palette-surface) !important;
        border-color: var(--mud-palette-lines-default) !important;
        color: var(--mud-palette-text-disabled) !important;
    }
</style>

@if (_processWorkflow != null)
{
    <MudStack Row="true" Spacing="4">
   
        @foreach (var step in _processWorkflow.Steps)
        {
            var transition = step.OutgoingTransition;

            <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">

                <MudPaper Outlined="true" Class="@($"wf-step {GetStepCssClass(step)}")" Style="width:250px;">

                    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">

                        @if (step.IsCompleted)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                        }
                        else if (step.IsActive)
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Pending" />
                        }

                        <MudText Typo="Typo.body2" Style="font-size:12px;">@LocalizedStringService.Get(@step.Key)</MudText>

                    </MudStack>

                </MudPaper>

                @if (transition != null)
                {
                    <MudStack Spacing="1" Row="true" AlignItems="AlignItems.Center">

                        @if (transition.Conditions.Any())
                        {
                            <MudTooltip Placement="Placement.Bottom" Arrow="true" Color="Color.Surface">
                                <TooltipContent>

                                    <MudPaper Class="pa-2" Elevation="2">

                                        @if (transition.Conditions.Any())
                                        {
                                            <MudStack Spacing="1" Style="padding:4px;min-width:200px;">
                                                @foreach (var condition in transition.Conditions)
                                                {
                                                    var style = condition.IsCompleted ? "color:var(--mud-palette-success-darken)" : "color:var(--mud-palette-error)";

                                                    <MudStack Spacing="1" Row="true" AlignItems="AlignItems.Center">
                                                        <BoolIndicator Value="condition.IsCompleted" />
                                                        <MudText Typo="Typo.caption" Style="@style">
                                                            @LocalizedStringService.Get(condition.Key)
                                                        </MudText>
                                                    </MudStack>
                                                }
                                            </MudStack>
                                        }
                                    </MudPaper>

                                </TooltipContent>
                                <ChildContent>
                                    <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Style="margin-top:4px;" Color="Color.Info" />
                                </ChildContent>
                            </MudTooltip>
                        }

                        <ActionButton Shrink="true"
                                      OnClick="() => ExecuteTransitionAsync(transition)"
                                      ActionKey="@StringKey.From(transition.GetActionKey())"
                                      Disabled="!transition.IsExecutable" />                        

                    </MudStack>
                }
            </MudStack>
        }

    </MudStack>
}

@code {
    [Parameter, EditorRequired] public string? WorkflowKey { get; set; }
    [Parameter, EditorRequired] public int? DomainObjectId { get; set; }
    [Parameter] public EventCallback<DomainObjectApplicationActionResultPayload?> OnTransitionExecuted { get; set; }

    private ProcessWorkflow? _processWorkflow;

    public async Task RefreshWorkflowAsync()
    {
        if (DomainObjectId != null && WorkflowKey != null)
        {
            _processWorkflow = await WorkflowServiceGateway.GetAsync(WorkflowKey, DomainObjectId.Value);

            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnInitializedAsync();

        await RefreshWorkflowAsync();
    }

    private string GetStepCssClass(Step step)
    {
        if (step.IsCompleted)
            return "wf-step-completed";

        if (step.IsActive)
            return "wf-step-active";

        return "wf-step-pending";
    }

    private async Task ExecuteTransitionAsync(Transition transition)
    {
        if (DomainObjectId != null && WorkflowKey != null)
        {
            DomainObjectApplicationActionResultPayload? payload = null;

            if (transition.DomainObjectHttpApplicationAction != null)
            {
                transition.DomainObjectHttpApplicationAction.DomainObjectId = DomainObjectId.Value;
                payload = await ApplicationActionExecutionService.ExecuteApplicationActionAsync(transition.DomainObjectHttpApplicationAction);
            }
            else if (transition.OpenDialogApplicationAction != null)
            {
                transition.OpenDialogApplicationAction.DialogTitle = LocalizedStringService.Get(transition.OpenDialogApplicationAction.ComponentKey);
                transition.OpenDialogApplicationAction.DomainObjectId = DomainObjectId.Value;
                payload = await ApplicationActionExecutionService.ExecuteApplicationActionAsync(transition.OpenDialogApplicationAction);
            }

            await RefreshWorkflowAsync();

            if (transition.ExecutionConfirmationMessageKey != null)
            {
                UserDialogService.SnackShow(LocalizedStringService.Get(transition.ExecutionConfirmationMessageKey)!);
            }

            if (OnTransitionExecuted.HasDelegate)
                await OnTransitionExecuted.InvokeAsync(payload);
        }
    }    
}
