@using BusinessAppFramework.Application.Interfaces
@using Application.Workflows
@using BusinessAppFramework.WebUI.Components.SearchList
@using MudBlazor

@inject ILocalizedStringService LocalizedStringService

<style>
    .wf-row {
        display: flex;
        gap: 12px;
    }

    .wf-step {
        flex: 1;
        padding: 12px;
        transition: border-color 0.15s ease;
        border-radius:12px;
    }

    .wf-step-completed {
        background-color: var(--mud-palette-success-hover) !important;
        border-color: var(--mud-palette-primary) !important;
        color: var(--mud-palette-success-darken) !important;
    }

    .wf-step-active {
        background-color: var(--mud-palette-secondary-hover) !important;
        border-color: var(--mud-palette-secondary-info) !important;
        border-width: 2px !important;
        padding: 11px !important; 
        color: var(--mud-palette-secondary-darken) !important;
    }

    .wf-step-pending {
        background-color: var(--mud-palette-surface) !important;
        border-color: var(--mud-palette-lines-default) !important;
        color: var(--mud-palette-text-disabled) !important;
    }
</style>

@if (Workflow != null)
{
    <div style="display: flex; gap: 4px;">

        @foreach (var step in Workflow.ProcessWorkflowSteps)
        {
            <MudPaper Outlined="true" Class="@($"wf-step {GetStepCssClass(step)}")">
                <MudStack Row="true" Justify="Justify.Center">
                    @if (step.IsCompleted)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Check" />
                    }
                    else if (_firstIncomplete == step)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Pending" />
                    }
                    <MudText>@LocalizedStringService.Get(@step.Key)</MudText>
                </MudStack>
            </MudPaper>
        }

    </div>

    @* <MudStepper CenterLabels="true"
                Class="wf-stepper"
                ErrorStepColor="Color.Error"
                CurrentStepColor="Color.Tertiary"
                @bind-ActiveIndex="_activeIndex">
        <ChildContent>
            @foreach (var step in Workflow.ProcessWorkflowSteps)
            {
                <MudStep Title="@LocalizedStringService.Get(step.Key)"
                         Completed="@step.IsCompleted">

                    <div style="display: flex; flex-direction: row; flex-wrap: wrap; gap: 6px; align-items: flex-start;">
                        @foreach (var condition in step.ProcessWorkflowStepConditions)
                        {
                            <div style="display: flex; align-items: center; gap: 8px;
                                        background: @(condition.IsCompleted ? "var(--mud-palette-success-hover)" : "var(--mud-palette-error-hover)");
                                        border: 1px solid @(condition.IsCompleted ? "var(--mud-palette-success)" : "var(--mud-palette-error)");
                                        border-radius: 8px;
                                        padding: 4px 10px;">
                                <BoolIndicator Value="condition.IsCompleted" />
                                <MudText Typo="Typo.caption">@LocalizedStringService.Get(condition.Key)</MudText>
                            </div>
                        }
                    </div>

                </MudStep>
            }
        </ChildContent>
        <ActionContent />

    </MudStepper> *@
}

@code {
    [Parameter] public ProcessWorkflow? Workflow { get; set; }

    private int _activeIndex;
    private ProcessWorkflowStep? _firstIncomplete;

    protected override void OnParametersSet()
    {
        if (Workflow?.ProcessWorkflowSteps is null || Workflow.ProcessWorkflowSteps.Count == 0)
            return;

        var index = Workflow.ProcessWorkflowSteps.FindIndex(s => !s.IsCompleted);

        _activeIndex = index >= 0 ? index : Workflow.ProcessWorkflowSteps.Count - 1;
    }

    private string GetStepCssClass(ProcessWorkflowStep step)
    {
        if (step.IsCompleted) 
            return "wf-step-completed";

        if (IsActive(step)) 
            return "wf-step-active";

        return "wf-step-pending";
    }

    private bool IsActive(ProcessWorkflowStep step)
    {
        _firstIncomplete = Workflow?.ProcessWorkflowSteps.FirstOrDefault(s => !s.IsCompleted);
        return _firstIncomplete == step;
    }
}
