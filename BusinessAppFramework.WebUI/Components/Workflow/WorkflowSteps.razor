@using BusinessAppFramework.Application.Interfaces
@using Application.Workflows
@using BusinessAppFramework.WebUI.Components.SearchList
@using MudBlazor

@inject ILocalizedStringService LocalizedStringService

@if (Workflow != null)
{
    <MudStepper CenterLabels="true"
                Class="wf-stepper"
                ErrorStepColor="Color.Error"
                CurrentStepColor="Color.Tertiary"
                @bind-ActiveIndex="_activeIndex">
        <ChildContent>
            @foreach (var step in Workflow.ProcessWorkflowSteps)
            {
                <MudStep Title="@LocalizedStringService.Get(step.Key)"
                         Completed="@step.IsCompleted">

                    <div style="display: flex; flex-direction: column; gap: 6px; align-items: flex-start;">
                        @foreach (var condition in step.ProcessWorkflowStepConditions)
                        {
                            <div style="display: flex; align-items: center; gap: 8px;
                                        background: @(condition.IsCompleted ? "var(--mud-palette-success-hover)" : "var(--mud-palette-error-hover)");
                                        border: 1px solid @(condition.IsCompleted ? "var(--mud-palette-success)" : "var(--mud-palette-error)");
                                        border-radius: 8px;
                                        padding: 4px 10px;">
                                <BoolIndicator Value="condition.IsCompleted" />
                                <MudText Typo="Typo.caption">@LocalizedStringService.Get(condition.Key)</MudText>
                            </div>
                        }
                    </div>

                </MudStep>
            }
        </ChildContent>
        <ActionContent />

    </MudStepper>
}

@code {
    [Parameter] public ProcessWorkflow? Workflow { get; set; }

    private int _activeIndex;

    protected override void OnParametersSet()
    {
        if (Workflow?.ProcessWorkflowSteps is null || Workflow.ProcessWorkflowSteps.Count == 0)
            return;

        var index = Workflow.ProcessWorkflowSteps.FindIndex(s => !s.IsCompleted);

        _activeIndex = index >= 0 ? index : Workflow.ProcessWorkflowSteps.Count - 1;
    }
}
