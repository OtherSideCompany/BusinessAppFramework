<UserControl x:Class="OtherSideCore.Wpf.UserControls.Filters.HoursMinutesEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Filters" 
             xmlns:customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="HoursMinutesEditorUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <customcontrols:ClickSelectTextBox Grid.Column="0" Width="32"
                                         Text="{Binding HoursMinutesEditor_Hours, Mode=TwoWay, UpdateSourceTrigger=LostFocus, ElementName=HoursMinutesEditorUserControl, StringFormat={}{0:0}}"                                             
                                         Style="{StaticResource EditorDecimalClickSelectTextBox}"
                                         HorizontalContentAlignment="Center"
                                         ClickSelectTextBox_TextMargin="2"/>
      
      <TextBlock Grid.Column="1" Text="h" Margin="4,0,4,0" VerticalAlignment="Center" Style="{StaticResource PropertyLabelTextBlock}"/>

      <customcontrols:ClickSelectTextBox Grid.Column="2" Width="32"
                                         Text="{Binding HoursMinutesEditor_Minutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus, ElementName=HoursMinutesEditorUserControl, StringFormat={}{0:0}}"
                                         Style="{StaticResource EditorDecimalClickSelectTextBox}"
                                         HorizontalContentAlignment="Center"
                                         ClickSelectTextBox_TextMargin="2"/>

      <TextBlock Grid.Column="3" Text="m" Margin="4,0,0,0" VerticalAlignment="Center" Style="{StaticResource PropertyLabelTextBlock}"/>
   </Grid>
</UserControl>
