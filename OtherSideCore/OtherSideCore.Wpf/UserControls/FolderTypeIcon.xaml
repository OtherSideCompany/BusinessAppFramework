<UserControl x:Class="OtherSideCore.Wpf.UserControls.FolderTypeIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="FolderTypeIconUserControl">
   <Grid>
      <osc_customcontrols:SvgViewer SvgViewer_ImageHeight="24"
                                    SvgViewer_ImageColor="{Binding FolderTypeIcon_FolderIconColor, ElementName=FolderTypeIconUserControl}"
                                    SvgViewer_ImageGeometry="{StaticResource icon_folder-outline}">
      </osc_customcontrols:SvgViewer>
   </Grid>
</UserControl>
