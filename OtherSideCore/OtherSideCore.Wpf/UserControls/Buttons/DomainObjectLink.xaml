<UserControl x:Class="OtherSideCore.Wpf.UserControls.Buttons.DomainObjectLink"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Buttons"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="DomainObjectLinkUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Button HorizontalAlignment="Left"
              Style="{StaticResource LinkButton}" 
              Content="{Binding DomainObjectLink_Name, ElementName=DomainObjectLinkUserControl}" 
              Command="{Binding DomainObjectLink_LinkClickedCommand, ElementName=DomainObjectLinkUserControl}"
              CommandParameter="{Binding DomainObjectLink_Id, ElementName=DomainObjectLinkUserControl}"/>

   </Grid>
</UserControl>
