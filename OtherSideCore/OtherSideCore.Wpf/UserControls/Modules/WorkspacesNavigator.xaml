<UserControl x:Class="OtherSideCore.Wpf.UserControls.Modules.WorkspacesNavigator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Modules"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="WorkspacesNavigatorUserControl">
   <UserControl.Resources>

      <SolidColorBrush Color="White" x:Key="ForegroundColor" />
      <SolidColorBrush Color="#17191c" x:Key="ButtonBackgroundColor" />
      <SolidColorBrush Color="#343638" x:Key="ButtonOverColor" />
      <SolidColorBrush Color="#404143" x:Key="ButtonIsPressedColor" />

      <Style TargetType="{x:Type Button}" x:Key="WorkspaceNavigationButton">
         <Setter Property="Width" Value="200" />
         <Setter Property="Height" Value="150" />
         <Setter Property="Margin" Value="10" />
         <Setter Property="Cursor" Value="Hand" />
         <Setter Property="Background" Value="{StaticResource ButtonBackgroundColor}" />
         <Setter Property="osc_extensions:ButtonExtension.OverColor" Value="{StaticResource ButtonOverColor}" />
         <Setter Property="osc_extensions:ButtonExtension.PressedColor" Value="{StaticResource ButtonIsPressedColor}" />
         <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibleOrCollapsed}}" />         
         <Setter Property="Template">
            <Setter.Value>
               <ControlTemplate TargetType="{x:Type Button}">
                  <Border x:Name="ButtonContainer" Background="{TemplateBinding Background}">
                     <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                  </Border>
                  <ControlTemplate.Triggers>
                     <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{Binding Path=(osc_extensions:ButtonExtension.OverColor), RelativeSource={RelativeSource TemplatedParent}}" TargetName="ButtonContainer"/>
                     </Trigger>
                     <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{Binding Path=(osc_extensions:ButtonExtension.PressedColor), RelativeSource={RelativeSource TemplatedParent}}" TargetName="ButtonContainer"/>
                     </Trigger>
                  </ControlTemplate.Triggers>
               </ControlTemplate>
            </Setter.Value>
         </Setter>
      </Style>

   </UserControl.Resources>
   <Grid>
      <ItemsControl ItemsSource="{Binding NavigationItems}" Grid.IsSharedSizeScope="True">
         <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
               <WrapPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="1000"  />
            </ItemsPanelTemplate>
         </ItemsControl.ItemsPanel>
         <ItemsControl.ItemTemplate>
            <DataTemplate>
               <Button Style="{StaticResource WorkspaceNavigationButton}"
                       Command="{Binding DataContext.SelectNavigationItemCommand, ElementName=WorkspacesNavigatorUserControl}"
                       CommandParameter="{Binding}">
                  <Border>
                     <Grid Margin="10">
                        <Grid.RowDefinitions>
                           <RowDefinition Height="*" />
                           <RowDefinition Height="Auto" SharedSizeGroup="A" />
                        </Grid.RowDefinitions>
                        <customcontrols:SvgViewer Grid.Row="0" 
                                                  SvgViewer_ImageColor="{StaticResource ForegroundColor}"
                                                  SvgViewer_ImageGeometry="{Binding IconKey, Converter={StaticResource GeometryResourceConverter}}"
                                                  SvgViewer_ImageHeight="36" 
                                                  SvgViewer_ImageWidth="36"/>
                        <TextBlock Grid.Row="1" Text="{Binding Label}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource ForegroundColor}"/>
                     </Grid>
                  </Border>
               </Button>
            </DataTemplate>
         </ItemsControl.ItemTemplate>
      </ItemsControl>
   </Grid>
</UserControl>
