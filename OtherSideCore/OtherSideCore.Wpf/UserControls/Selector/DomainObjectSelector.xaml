<UserControl x:Class="OtherSideCore.Wpf.UserControls.Selector.DomainObjectSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Selector"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="DomainObjectSelectorUserControl">
   <Border Grid.Column="0" Style="{StaticResource WorkspaceBorder}">

      <Grid>
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
         </Grid.RowDefinitions>

         <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding DomainObjectSelector_Name, ElementName=DomainObjectSelectorUserControl}" Style="{StaticResource ViewHeader}" Margin="0,0,0,8" />

            <osc_customcontrols:SvgImageButton Grid.Column="1" HorizontalAlignment="Right" Width="32" Height="32"
                                               Background="{StaticResource MMColor_Green}"
                                               SvgImageButton_ImageColor="White"
                                               SvgImageButton_IconGeometry="{StaticResource icon_navigation-variant-outline}"
                                               SvgImageButton_ImageSize="20"
                                               ToolTip="Ouvrir le module pour ajout et édition" 
                                               Command="{Binding DisplayDomainObjectBrowserAsyncCommand}"/>

         </Grid>

         <Border Grid.Row="1" Style="{StaticResource RibonBorderStyle}" Margin="0,8,0,8">

            <ContentControl Content="{Binding DomainObjectSelector_ConstraintsContent, ElementName=DomainObjectSelectorUserControl}"  
                            DataContext="{Binding DomainObjectSearchViewModel}"/>

         </Border>

         <Border Grid.Row="2" Height="Auto" MinHeight="32" Margin="0,0,0,0">

            <ContentControl Content="{Binding DomainObjectSelector_FiltersContent, ElementName=DomainObjectSelectorUserControl}" 
                            DataContext="{Binding DomainObjectSearchViewModel}"/>

         </Border>

         <Grid Grid.Row="3" Margin="0,8,0,0">

            <ContentControl Content="{Binding DomainObjectSelector_ListContent, ElementName=DomainObjectSelectorUserControl}" />

         </Grid>

         <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Height="32" Margin="0,16,0,0">

            <osc_customcontrols:SvgImageTextButton Margin="8,0,0,0" 
                                                   Style="{StaticResource SvgImageTextButtonDark}"
                                                   SvgImageTextButton_Text="Valider la sélection"
                                                   SvgImageTextButton_IconGeometry="{StaticResource icon_check}"
                                                   SvgImageTextButton_ImageSize="20" 
                                                   Command="{Binding ValidateSelectionCommand}" />

         </StackPanel>


      </Grid>

   </Border>
</UserControl>
