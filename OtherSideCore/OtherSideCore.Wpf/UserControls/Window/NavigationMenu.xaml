<UserControl x:Class="OtherSideCore.Wpf.UserControls.Window.NavigationMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="NavigationMenuUserControl">
   <UserControl.Resources>
      <ResourceDictionary>
         <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="pack://application:,,,/OtherSideCore.Wpf;component/Converters/Converters.xaml"/>
            <ResourceDictionary Source="pack://application:,,,/OtherSideCore.Wpf;component/Icons/Icons.xaml"/>
         </ResourceDictionary.MergedDictionaries>

         <SolidColorBrush Color="#ededed" x:Key="NavigationMenuBackgroundColor" />
         <SolidColorBrush Color="White" x:Key="ButtonOverBackgroundColor" />
         <SolidColorBrush Color="White" x:Key="ButtonIsPressedBackgroundColor" />
         <SolidColorBrush Color="White" x:Key="ButtonIsCheckedBackgroundColor" />
         <SolidColorBrush Color="#777676" x:Key="ForegroundColor" />
         <SolidColorBrush Color="#e8e7e8" x:Key="NavigationMenuBorderBrushForegroundColor" />     

      </ResourceDictionary>
   </UserControl.Resources>
   <Border Background="{StaticResource NavigationMenuBackgroundColor}"
           BorderThickness="0,0,1,0"
           BorderBrush="{StaticResource NavigationMenuBorderBrushForegroundColor}">
      <Grid>
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
         </Grid.RowDefinitions>

         <Border Grid.Row="0">
            <customcontrols:SvgImageToggleButton x:Name="MenuToggleButton"
                                                 Background="Transparent" 
                                                 Height="32"
                                                 Width="38"
                                                 BorderThickness="0"
                                                 HorizontalAlignment="Left"
                                                 SvgImageToggleButton_ImageSize="24"
                                                 SvgImageToggleButton_IconGeometry="{StaticResource icon_menu}"
                                                 SvgImageToggleButton_OverBackgroundColor="{StaticResource ButtonOverBackgroundColor}"
                                                 SvgImageToggleButton_MouseDownBackgroundColor="{StaticResource ButtonIsPressedBackgroundColor}"
                                                 SvgImageToggleButton_CheckedBackgroundColor="Transparent"
                                                 SvgImageToggleButton_ImageColor="{StaticResource ForegroundColor}"/>
         </Border>

         <ItemsControl Grid.Row="1"
                       ItemsSource="{Binding NavigationItems}">
            <ItemsControl.ItemsPanel>
               <ItemsPanelTemplate>
                  <StackPanel Orientation="Vertical" />
               </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <Grid>

                     <Button Cursor="Hand"
                             Command="{Binding DataContext.SelectNavigationItemCommand, ElementName=NavigationMenuUserControl}"
                             CommandParameter="{Binding}"
                             Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibleOrCollapsed}}">
                        <Button.Style>
                           <Style TargetType="{x:Type Button}">
                              <Setter Property="Background" Value="Transparent" />
                              <Setter Property="Template">
                                 <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                       <Grid Background="{TemplateBinding Background}">
                                          <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="*" />
                                          </Grid.ColumnDefinitions>

                                          <customcontrols:SvgViewer Grid.Column="0" Width="38" Height="38"
                                                                    SvgViewer_ImageWidth="20"
                                                                    SvgViewer_ImageColor="{StaticResource ForegroundColor}" 
                                                                    SvgViewer_ImageGeometry="{Binding IconKey, Converter={StaticResource GeometryResourceConverter}}" />

                                          <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="14" VerticalAlignment="Center"
                                                     Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BoolToVisibleOrCollapsed}}"
                                                     Foreground="{StaticResource ForegroundColor}" Margin="0,0,15,0"/>
                                       </Grid>
                                    </ControlTemplate>
                                 </Setter.Value>
                              </Setter>
                              <Style.Triggers>
                                 <DataTrigger Binding="{Binding IsSelected, Mode=OneWay}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ButtonIsCheckedBackgroundColor}"/>
                                 </DataTrigger>
                                 <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ButtonOverBackgroundColor}"/>
                                 </Trigger>
                              </Style.Triggers>
                           </Style>
                        </Button.Style>
                     </Button>

                  </Grid>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>

      </Grid>
   </Border>
</UserControl>
