<UserControl x:Class="OtherSideCore.Wpf.UserControls.Editor.DomainObjectReferencesEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Editor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:list="clr-namespace:OtherSideCore.Wpf.UserControls.List"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="DomainObjectReferencesEditorUserControl">
    <Grid>
      <ItemsControl ItemsSource="{Binding RelationEntryViewModels}"
                    Grid.IsSharedSizeScope="True">
         <ItemsControl.ItemTemplate>
            <DataTemplate>
               <Grid Visibility="{Binding RelationEntry.IsSystemManaged, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=invert}"
                     x:Name="RelationEntryGrid">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto" SharedSizeGroup="Label" />
                     <ColumnDefinition Width="*" />
                     <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0" Style="{StaticResource PropertyLabelTextBlock}" Text="{Binding RelationName}" />

                  <Grid Grid.Column="1" Margin="0,4,0,4" >

                     <list:EmptyListIndicator DataContext="{Binding DomainObjectReferenceViewModels}" 
                                              EmptyListIndicator_Text="Non défini" 
                                              EmptyListIndicator_TextHorizontalAlignment="Left"/>

                     <ItemsControl ItemsSource="{Binding DomainObjectReferenceViewModels}">
                        <ItemsControl.ItemTemplate>
                           <DataTemplate>
                              <local:DomainObjectReferenceView DomainObjectReferenceView_DeleteReferenceCommand="{Binding DataContext.DeleteDomainObjectReferenceAsyncCommand, ElementName=RelationEntryGrid}" 
                                                               DomainObjectReferenceView_DataTemplateSelector="{Binding DomainObjectReferencesEditor_DataTemplateSelector, ElementName=DomainObjectReferencesEditorUserControl}" />
                           </DataTemplate>
                        </ItemsControl.ItemTemplate>
                     </ItemsControl>

                  </Grid>                  

               </Grid>
            </DataTemplate>
         </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
</UserControl>
