<UserControl x:Class="OtherSideCore.Wpf.UserControls.Editor.DomainObjectReferenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Editor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions" 
             xmlns:buttons="clr-namespace:OtherSideCore.Wpf.UserControls.Buttons"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="DomainObjectReferenceViewUserControl">
   <Border CornerRadius="8"
           BorderThickness="1"
           BorderBrush="{StaticResource OtherSide_LightGray}"
           Background="White"
           Height="32"
           Margin="0,0,4,0">
      <Grid>
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />

         </Grid.ColumnDefinitions>

         <ContentPresenter Content="{Binding DomainObjectReference.ReferenceType}" 
                           ContentTemplateSelector="{Binding DomainObjectReferenceView_DataTemplateSelector, ElementName=DomainObjectReferenceViewUserControl}"/>

         <buttons:DomainObjectLink Grid.Column="1" Margin="8,0,0,0" 
                                   DomainObjectLink_Id="{Binding DomainObjectReference.DomainObjectId}"
                                   DomainObjectLink_DomainObjectType="{Binding DomainObjectReference.ReferenceType}"
                                   DomainObjectLink_Name="{Binding DomainObjectReference.ReferenceNumber}" />

         <osc_customcontrols:SvgImageButton Grid.Column="2"
                                            BorderThickness="0"
                                            Width="24" 
                                            Margin="-4,4,4,4"
                                            SvgImageButton_IconGeometry="{StaticResource icon_close}" 
                                            SvgImageButton_ImageSize="12" 
                                            Command="{Binding DomainObjectReferenceView_DeleteReferenceCommand, ElementName=DomainObjectReferenceViewUserControl}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DomainObjectReferenceView_DeleteReferenceCommand, ElementName=DomainObjectReferenceViewUserControl, Converter={StaticResource NullToVisibilityConverter}}"/>

      </Grid>
   </Border>
</UserControl>
