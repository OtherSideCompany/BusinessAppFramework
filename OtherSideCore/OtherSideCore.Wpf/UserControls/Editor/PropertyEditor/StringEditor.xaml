<UserControl x:Class="OtherSideCore.Wpf.UserControls.Editor.PropertyEditor.StringEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Editor.PropertyEditor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="StringEditorUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>      
   
      <customcontrols:ClickSelectTextBox Text="{Binding StringEditor_Text, ElementName=StringEditorUserControl, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource EditorClickSelectTextBox}" />

      <customcontrols:SvgImageButton Grid.Column="1"
                                     Width="32"
                                     Height="32"
                                     Margin="4,0,0,0"
                                     SvgImageButton_IconGeometry="{Binding CustomSetCommandIconResource, ElementName=StringEditorUserControl, Converter={StaticResource GeometryResourceConverter}}"
                                     Command="{Binding CustomSetCommand, ElementName=StringEditorUserControl}"
                                     Visibility="{Binding CustomSetCommand, ElementName=StringEditorUserControl, Converter={StaticResource NullToVisibilityConverter}}" />

   </Grid>
</UserControl>
