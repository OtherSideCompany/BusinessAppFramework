<UserControl x:Class="OtherSideCore.Wpf.UserControls.Editor.PropertyEditor.BooleanEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Editor.PropertyEditor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="BooleanEditorUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      
      <CheckBox IsChecked="{Binding BooleanEditor_IsChecked, ElementName=BooleanEditorUserControl, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                Style="{StaticResource EditorCheckBox}" />

      <osc_customcontrols:SvgImageButton Grid.Column="1"
                                         Width="32"
                                         Height="32"
                                         Margin="4,0,0,0"
                                         SvgImageButton_IconGeometry="{Binding CustomSetCommandIconResource, ElementName=BooleanEditorUserControl, Converter={StaticResource GeometryResourceConverter}}"
                                         Command="{Binding CustomSetCommand, ElementName=BooleanEditorUserControl}"
                                         Visibility="{Binding CustomSetCommand, ElementName=BooleanEditorUserControl, Converter={StaticResource NullToVisibilityConverter}}" />
   </Grid>
</UserControl>
