<UserControl x:Class="OtherSideCore.Wpf.UserControls.Editor.PropertyEditor.IntegerEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Editor.PropertyEditor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="IntegerEditorUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <osc_customcontrols:ClickSelectTextBox Grid.Column="0" 
                                             Text="{Binding IntegerEditor_Value, UpdateSourceTrigger=LostFocus, ElementName=IntegerEditorUserControl}" 
                                             Style="{StaticResource EditorIntegerClickSelectTextBox}" />

      <osc_customcontrols:SvgImageButton Grid.Column="1"
                                         Width="32"
                                         Height="32"
                                         Margin="4,0,0,0"
                                         SvgImageButton_IconGeometry="{Binding CustomSetCommandIconResource, ElementName=IntegerEditorUserControl, Converter={StaticResource GeometryResourceConverter}}"
                                         Command="{Binding CustomSetCommand, ElementName=IntegerEditorUserControl}"
                                         Visibility="{Binding CustomSetCommand, ElementName=IntegerEditorUserControl, Converter={StaticResource NullToVisibilityConverter}}" />

   </Grid>
</UserControl>
