<UserControl x:Class="SystemAdministration.Desktop.PropertyEditors.SelectorPropertyEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SystemAdministration.Desktop.PropertyEditors"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="UserPropertyEditorUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <osc_customcontrols:ClickSelectTextBox Grid.Column="0" 
                                             Text="{Binding SelectorPropertyEditor_DomainObject, ElementName=UserPropertyEditorUserControl, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ToStringConverter}}" 
                                             Style="{StaticResource EditorClickSelectTextBox}" IsReadOnly="True" />

      <osc_customcontrols:SvgImageButton Grid.Column="1" Width="32" Height="32" Margin="4,0,0,0"
                                         SvgImageButton_IconGeometry="{StaticResource icon_magnify}" 
                                         Command="{Binding UserPropertyEditor_DisplaySelectorCommand, ElementName=UserPropertyEditorUserControl}"/>

   </Grid>
</UserControl>
