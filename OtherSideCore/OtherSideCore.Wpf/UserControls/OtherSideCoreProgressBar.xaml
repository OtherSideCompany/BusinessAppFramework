<UserControl x:Class="OtherSideCore.Wpf.UserControls.OtherSideCoreProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="OtherSideCoreProgressBarUserControl">
   <Grid>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,24" HorizontalAlignment="Right">

         <osc_customcontrols:SvgViewer Width="16" Height="16" Margin="0,0,4,0"
                                       SvgViewer_ImageGeometry="{StaticResource icon_alert-circle}" 
                                       SvgViewer_ImageHeight="16"
                                       SvgViewer_ImageColor="Orange"
                                       Visibility="{Binding OtherSideCoreProgressBar_IsValueExceeded, Converter={StaticResource BoolToVisibleOrCollapsed}, ElementName=OtherSideCoreProgressBarUserControl }"
                                       ToolTip="Valeur maximale dépassée"/>
         <TextBlock FontSize="11">
            <Run Text="{Binding OtherSideCoreProgressBar_Value, ElementName=OtherSideCoreProgressBarUserControl}" />
            <Run Text="/" />
            <Run Text="{Binding OtherSideCoreProgressBar_Maximum, ElementName=OtherSideCoreProgressBarUserControl}" />
         </TextBlock>
         
      </StackPanel>

      <ProgressBar Minimum="{Binding OtherSideCoreProgressBar_Minimum, ElementName=OtherSideCoreProgressBarUserControl}" 
                   Maximum="{Binding OtherSideCoreProgressBar_Maximum, ElementName=OtherSideCoreProgressBarUserControl}" 
                   Value="{Binding OtherSideCoreProgressBar_Value, ElementName=OtherSideCoreProgressBarUserControl}"
                   Foreground="{Binding OtherSideCoreProgressBar_BarColor, ElementName=OtherSideCoreProgressBarUserControl}"
                   Background="{StaticResource OtherSide_LightGray}">
         <ProgressBar.Style>
            <Style TargetType="{x:Type ProgressBar}">
               <Setter Property="Template">
                  <Setter.Value>
                     <ControlTemplate TargetType="{x:Type ProgressBar}" >
                        <Grid x:Name="Root">
                           <Border Name="PART_Track" 
                                   Height="4"
                                   CornerRadius="2" 
                                   Background="{TemplateBinding Background}"
                                   BorderBrush="{TemplateBinding Background}"
                                   BorderThickness="2" />
                           <Border Name="PART_Indicator" 
                                   Height="4"
                                   CornerRadius="2" 
                                   Background="{TemplateBinding Foreground}" 
                                   BorderBrush="{TemplateBinding Foreground}" 
                                   BorderThickness="2" 
                                   HorizontalAlignment="Left" />
                        </Grid>

                     </ControlTemplate>
                  </Setter.Value>
               </Setter>
            </Style>
         </ProgressBar.Style>
      </ProgressBar>
      
   </Grid>
</UserControl>
