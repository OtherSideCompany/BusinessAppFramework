<UserControl x:Class="OtherSideCore.Wpf.UserControls.NullableIntegerDatabaseFieldEditionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Border Style="{StaticResource EditableTextBoxBorder}" CornerRadius="5">
      <osc_customcontrols:ClickSelectTextBox Text="{Binding Buffer, UpdateSourceTrigger=PropertyChanged}" 
                                      IsReadOnly="{Binding IsEditable, Converter={StaticResource BoolInverter}}"
                                      LostFocus="NullableIntegerTextBox_LostFocus"
                                      Margin="4,0,4,0" />
   </Border>
</UserControl>
