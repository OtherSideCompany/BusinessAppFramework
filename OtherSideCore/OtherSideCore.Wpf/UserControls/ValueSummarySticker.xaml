<UserControl x:Class="OtherSideCore.Wpf.UserControls.ValueSummarySticker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="KpiUserControl">
    <Grid>
      <Border Grid.Column="0"
              BorderThickness="1"
              BorderBrush="{StaticResource OtherSide_LightGray}"
              CornerRadius="8"
              Padding="16,8,16,8">
         <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto" />
               <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                    Background="{StaticResource OtherSide_LightLightGray}"
                    CornerRadius="8"
                    Width="32" 
                    Height="32"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0">
               <osc_customcontrols:SvgViewer SvgViewer_ImageGeometry="{Binding ValueSummarySticker_IconGeometry, ElementName=KpiUserControl}"
                                             SvgViewer_ImageHeight="20"
                                             SvgViewer_ImageColor="{Binding ValueSummarySticker_IconColor, ElementName=KpiUserControl}"/>
            </Border>

            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyLabelTextBlock}" Margin="0" Text="{Binding ValueSummarySticker_Text, ElementName=KpiUserControl}" FontSize="14" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ValueSummarySticker_Value, ElementName=KpiUserControl}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{Binding ValueSummarySticker_ValueTextColor, ElementName=KpiUserControl}"/>

         </Grid>
      </Border>
   </Grid>
</UserControl>
