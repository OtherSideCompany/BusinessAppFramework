<UserControl x:Class="OtherSideCore.Wpf.UserControls.Tag"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="TagUserControl">
   <Grid>

      <Border Background="{Binding Tag_Background, ElementName=TagUserControl}"
              CornerRadius="8">
         <TextBlock Margin="4"
                    Text="{Binding Tag_Text, ElementName=TagUserControl}" 
                    Foreground="{Binding Tag_Foreground, ElementName=TagUserControl}"/>
      </Border>

   </Grid>
</UserControl>
