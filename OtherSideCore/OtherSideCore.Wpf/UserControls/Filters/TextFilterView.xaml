<UserControl x:Class="OtherSideCore.Wpf.UserControls.Filters.TextFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Filters"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions" 
             xmlns:domainobjectbrowser="clr-namespace:OtherSideCore.Adapter.DomainObjectInteraction;assembly=OtherSideCore.Adapter"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Grid Visibility="{Binding IsInAdvancedSearchMode, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=invert}">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
         </Grid.ColumnDefinitions>

         <local:SingleTextFilter Grid.Column="0" DataContext="{Binding SingleTextFilterViewModel}" Margin="4,0,0,0" />

         <osc_customcontrols:SvgImageButton Grid.Column="1" Width="32" Height="32" Margin="4,0,0,0"
                                            SvgImageButton_ImageSize="16" 
                                            SvgImageButton_IconGeometry="{StaticResource icon_magnify}"
                                            Command="{Binding PaginatedSearchCommandAsync}">
            <osc_customcontrols:SvgImageButton.CommandParameter>
               <domainobjectbrowser:PaginatedSearchParameters ResetPage="{StaticResource True}" ExtendedSearch="{StaticResource False}" ParentViewModel="{x:Null}" />
            </osc_customcontrols:SvgImageButton.CommandParameter>
         </osc_customcontrols:SvgImageButton>

      </Grid>

      <Grid Visibility="{Binding IsInAdvancedSearchMode, Converter={StaticResource BoolToVisibleOrCollapsed}}">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
         </Grid.ColumnDefinitions>

         <local:MultiTextFilterView Grid.Column="0" DataContext="{Binding MultiTextFilterViewModel}" Margin="0,0,0,0" />

         <osc_customcontrols:SvgImageButton Grid.Column="2" Width="32" Height="32" Margin="4,0,0,0"
                                            SvgImageButton_ImageSize="16" 
                                            SvgImageButton_IconGeometry="{StaticResource icon_magnify}"
                                            Command="{Binding PaginatedSearchCommandAsync}">
            <osc_customcontrols:SvgImageButton.CommandParameter>
               <domainobjectbrowser:PaginatedSearchParameters ResetPage="{StaticResource True}" ExtendedSearch="{StaticResource False}" ParentViewModel="{x:Null}" />
            </osc_customcontrols:SvgImageButton.CommandParameter>
         </osc_customcontrols:SvgImageButton>

         <osc_customcontrols:SvgImageButton Grid.Column="3" Width="32" Height="32" Margin="4,0,0,0"
                                            SvgImageButton_ImageSize="16" 
                                            SvgImageButton_IconGeometry="{StaticResource icon_magnify-expand}"
                                            Command="{Binding PaginatedSearchCommandAsync}">
            <osc_customcontrols:SvgImageButton.CommandParameter>
               <domainobjectbrowser:PaginatedSearchParameters ResetPage="{StaticResource True}" ExtendedSearch="{StaticResource True}" ParentViewModel="{x:Null}" />
            </osc_customcontrols:SvgImageButton.CommandParameter>
         </osc_customcontrols:SvgImageButton>
      </Grid>

      <osc_customcontrols:SvgImageToggleButton Grid.Column="1" Width="32" Height="32" Margin="4,0,0,0"
                                               IsChecked="{Binding IsInAdvancedSearchMode}"
                                               SvgImageToggleButton_IconGeometry="{StaticResource icon_magnify_plus}"
                                               SvgImageToggleButton_CheckedIconGeometry="{StaticResource icon_magnify_minus}"
                                               SvgImageToggleButton_ImageSize="16"
                                               BorderThickness="0"
                                               Background="{StaticResource MMColor_Green}"
                                               SvgImageToggleButton_CheckedBackgroundColor="{StaticResource MMColor_Green}"
                                               SvgImageToggleButton_OverBackgroundColor="{StaticResource MMColor_Green}"
                                               SvgImageToggleButton_ImageColor="White" 
                                               ToolTip="Changer le mode de filtrage" />
   </Grid>
</UserControl>
