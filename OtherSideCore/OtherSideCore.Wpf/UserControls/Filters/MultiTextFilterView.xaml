<UserControl x:Class="OtherSideCore.Wpf.UserControls.Filters.MultiTextFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Filters" 
             xmlns:customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="MultiTextFilterViewUserControl">

   <Grid Background="Transparent">
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <customcontrols:SvgImageButton Grid.Column="0" Width="32" Height="32" 
                                     SvgImageButton_ImageSize="16" 
                                     SvgImageButton_IconGeometry="{StaticResource icon_filter-plus-outline}"
                                     Command="{Binding AddFilterCommand}" />

      <ItemsControl Grid.Column="1" 
                    ItemsSource="{Binding Filters}" 
                    VerticalAlignment="Center" 
                    Margin="8,0,0,0"
                    Visibility="{Binding Filters.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
         <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
               <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
         </ItemsControl.ItemsPanel>
         <ItemsControl.ItemTemplate>
            <DataTemplate>
               <Border Background="{StaticResource OtherSide_LightGray}"
                             Margin="0,0,4,0" 
                             CornerRadius="5"
                             VerticalAlignment="Center"
                             Height="32">
                  <Grid>
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" />
                     </Grid.ColumnDefinitions>

                     <customcontrols:ClickSelectTextBox Background="Transparent"
                                                              Grid.Column="0"
                                                              Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                                                              VerticalAlignment="Center">
                     </customcontrols:ClickSelectTextBox>

                     <customcontrols:SvgImageButton Grid.Column="1" Width="24" Height="24" Margin="0,0,4,0"
                                                          SvgImageButton_ImageSize="12" 
                                                          SvgImageButton_IconGeometry="{StaticResource icon_close}"
                                                          SvgImageButton_OverBackgroundColor="{StaticResource OtherSide_LightGray}"
                                                          BorderThickness="0"
                                                          Command="{Binding DataContext.RemoveFilterCommand, ElementName=MultiTextFilterViewUserControl}"                                                     
                                                          CommandParameter="{Binding}" />
                  </Grid>
               </Border>
            </DataTemplate>
         </ItemsControl.ItemTemplate>
      </ItemsControl>      

      <customcontrols:SvgImageTextButton Grid.Column="2" Height="32" Margin="4,0,0,0"
                                         SvgImageTextButton_IconGeometry="{StaticResource icon_close}"
                                         SvgImageTextButton_Text="Effacer les filtres"
                                         SvgImageTextButton_ImageColor="{StaticResource OtherSide_Gray}"
                                         SvgImageTextButton_ImageSize="16"
                                         Foreground="{StaticResource OtherSide_Gray}"
                                         Command="{Binding ClearFiltersCommand}"
                                         Visibility="{Binding Filters.Count, Converter={StaticResource ZeroToVisibilityConverter}}" />


   </Grid>
</UserControl>
