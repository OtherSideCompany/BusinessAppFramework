   <!-- Info Panel Category -->
   <Style TargetType="{x:Type ToggleButton}" x:Key="InfoPanelCategoryHeaderToggleButton">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type ToggleButton}">
               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto" />
                     <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <ContentPresenter Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Height="{TemplateBinding Height}" />

                  <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                     <local:SvgImageToggleButton SvgImageToggleButton_IconGeometry="{StaticResource icon_chevron-right}" 
                                                 SvgImageToggleButton_CheckedIconGeometry="{StaticResource icon_chevron-down}"
                                                 SvgImageToggleButton_CheckedBackgroundColor="Transparent"
                                                 SvgImageToggleButton_OverBackgroundColor="Transparent"
                                                 SvgImageToggleButton_ImageSize="20"
                                                 BorderThickness="0"
                                                 Height="{TemplateBinding Height}"
                                                 Margin="2,4,0,0"
                                                 IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}"/>
                  </Grid>

                  <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="1" BorderThickness="0" BorderBrush="{StaticResource OtherSide_DarkGray}" />

               </Grid>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type local:InfoPanelCategory}">
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type local:InfoPanelCategory}">
               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Border Grid.Row="0" Margin="16,0,16,0">
                     <ToggleButton x:Name="HeaderToggleButton"
                                   VerticalAlignment="Center"
                                   IsChecked="{Binding InfoPanelCategory_IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type local:InfoPanelCategory}}}"
                                   Style="{StaticResource InfoPanelCategoryHeaderToggleButton}"
                                   Content="{Binding InfoPanelCategory_HeaderName, RelativeSource={RelativeSource AncestorType={x:Type local:InfoPanelCategory}}}"
                                   Cursor="Hand"/>
                  </Border>

                  <ContentPresenter Grid.Row="1" 
                                    Margin="16,8,16,8"
                                    Visibility="{Binding IsChecked, ElementName=HeaderToggleButton, Converter={StaticResource BoolToVisibleOrCollapsed}}" />

                  <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" 
                          Height="1" 
                          BorderThickness="1" 
                          BorderBrush="{StaticResource OtherSide_LightGray}"   
                          Margin="0,8,0,0"
                          Visibility="{Binding InfoPanelCategory_DisplaySeparator, Converter={StaticResource BoolToVisibleOrCollapsed}, RelativeSource={RelativeSource AncestorType={x:Type local:InfoPanelCategory}}}"/>

               </Grid>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <!-- Text Radio Button -->
   <Style TargetType="{x:Type local:TextRadioButton}">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type RadioButton}">
               <StackPanel Background="Transparent">
                  <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TextRadioButton_Text}" 
                             FontWeight="DemiBold"
                             Foreground="Black"
                             HorizontalAlignment="Center"
                             x:Name="ConstraintName"/>
                  <Border Height="2" 
                          SnapsToDevicePixels="True" 
                          Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TextRadioButton_SelectedColor}" 
                          Margin="0,3,0,0"
                 x:Name="UnderlineBorder" Visibility="Hidden"/>
               </StackPanel>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsChecked" Value="True">
                     <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TextRadioButton_SelectedColor}" TargetName="ConstraintName" />
                     <Setter Property="Visibility" Value="Visible" TargetName="UnderlineBorder" />
                     <Setter Property="FontWeight" Value="Bold" TargetName="ConstraintName" />
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>

         </Setter.Value>
      </Setter>
   </Style>

   <!-- Text Toggle Button -->
   <Style TargetType="{x:Type local:TextToggleButton}">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="TextToggleButton_CheckedBackgroundColor" Value="{Binding TextToggleButton_OverBackgroundColor, RelativeSource={RelativeSource Self}}" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type local:TextToggleButton}">
               <Border Width="{TemplateBinding Width}" 
                    Height="{TemplateBinding Height}" 
                    Background="{TemplateBinding Background}"
                    x:Name="Border"
                    BorderBrush="{StaticResource OtherSide_LightGray}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="4,0,4,0">

                  <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                             Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content}" 
                             TextWrapping="NoWrap"/>

               </Border>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Background" Value="{Binding TextToggleButton_OverBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                  </Trigger>
                  <Trigger Property="IsChecked" Value="True">
                     <Setter Property="Background" Value="{Binding TextToggleButton_CheckedBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                     <Setter Property="BorderThickness" Value="0" TargetName="Border"/>
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                     <Setter Property="Background" Value="{Binding TextToggleButton_MouseDownBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

