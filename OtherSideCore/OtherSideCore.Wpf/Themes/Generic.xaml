                     <Setter Property="Background" Value="{Binding SvgImageTextRadioButton_CheckedBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                     <Setter Property="BorderThickness" Value="0" TargetName="Border"/>
                     <Setter Property="SvgViewer_ImageGeometry" Value="{Binding SvgImageTextRadioButton_CheckedIconGeometry, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Image"/>
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                     <Setter Property="Background" Value="{Binding SvgImageTextRadioButton_MouseDownBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                     <Setter Property="SvgViewer_ImageGeometry" Value="{Binding SvgImageTextRadioButton_IconGeometry, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Image"/>
                  </Trigger>
                  <Trigger Property="SvgImageTextRadioButton_Orientation" Value="Vertical">
                     <Setter Property="Orientation" Value="Vertical" TargetName="StackPanel" />
