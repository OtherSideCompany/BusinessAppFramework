   <!-- Info Panel Category -->  
   <Style TargetType="{x:Type local:InfoPanelCategory}">
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type local:InfoPanelCategory}">
               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <Border Grid.Row="0" Margin="16,0,16,0">
                     <ToggleButton x:Name="HeaderToggleButton"
                                   VerticalAlignment="Center"
                                   IsChecked="{Binding InfoPanelCategory_IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type local:InfoPanelCategory}}}"
                                   Style="{StaticResource TextExpanderHeaderToggleButton}"
                                   Content="{Binding InfoPanelCategory_HeaderName, RelativeSource={RelativeSource AncestorType={x:Type local:InfoPanelCategory}}}"/>
                  </Border>

                  <ContentPresenter Grid.Row="1" 
                                    Margin="16,8,16,8"
                                    Visibility="{Binding IsChecked, ElementName=HeaderToggleButton, Converter={StaticResource BoolToVisibleOrCollapsed}}" />

                  <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" 
                          Height="1" 
                          BorderThickness="1" 
                          BorderBrush="{StaticResource OtherSide_LightGray}"   
                          Margin="0,8,0,0"
                          Visibility="{Binding InfoPanelCategory_DisplaySeparator, Converter={StaticResource BoolToVisibleOrCollapsed}, RelativeSource={RelativeSource AncestorType={x:Type local:InfoPanelCategory}}}"/>

               </Grid>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>  

   <!-- Text Radio Button -->
   <Style TargetType="{x:Type local:TextRadioButton}">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type local:TextRadioButton}">
               <Border Width="{TemplateBinding Width}" 
                       Height="{TemplateBinding Height}" 
                       Background="{TemplateBinding Background}"
                       x:Name="Border"
                       BorderBrush="{StaticResource OtherSide_LightGray}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="8"
                       Padding="8,0,8,0">

                  <TextBlock VerticalAlignment="Center" 
                             HorizontalAlignment="Center"
                             Text="{Binding TextRadioButton_Text, RelativeSource={RelativeSource TemplatedParent}}" 
                             TextWrapping="NoWrap"/>

               </Border>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Background" Value="{Binding TextRadioButton_OverBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                  </Trigger>
                  <Trigger Property="IsChecked" Value="True">
                     <Setter Property="Background" Value="{Binding TextRadioButton_CheckedBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                     <Setter Property="BorderThickness" Value="0" TargetName="Border"/>
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                     <Setter Property="Background" Value="{Binding TextRadioButton_MouseDownBackgroundColor, RelativeSource={RelativeSource TemplatedParent}}" TargetName="Border"/>
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>

         </Setter.Value>
      </Setter>
   </Style>

   <!-- Text Toggle Button -->
   <Style TargetType="{x:Type local:TextToggleButton}">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="TextToggleButton_CheckedBackgroundColor" Value="{Binding TextToggleButton_OverBackgroundColor, RelativeSource={RelativeSource Self}}" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type local:TextToggleButton}">
               <Border Width="{TemplateBinding Width}" 
                    Height="{TemplateBinding Height}" 
                    Background="{TemplateBinding Background}"
                    x:Name="Border"
                    BorderBrush="{StaticResource OtherSide_LightGray}"
