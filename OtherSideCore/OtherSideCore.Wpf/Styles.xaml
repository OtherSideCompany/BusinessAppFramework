                  <customControls:SvgImageToggleButton Grid.Row="0" Grid.Column="0" Width="20" Height="20"
                                                       x:Name="ExpanderToggleButton"
                                                       Background="Transparent"
                                                       Margin="0,0,4,0"
                                                       IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}, Mode=TwoWay}"
                                                       SvgImageToggleButton_IconGeometry="{StaticResource icon_chevron-right}"
                                                       SvgImageToggleButton_CheckedIconGeometry="{StaticResource icon_chevron-down}"
                                                       SvgImageToggleButton_ImageSize="16"
                                                       SvgImageToggleButton_OverBackgroundColor="Transparent"
                                                       SvgImageToggleButton_CheckedBackgroundColor="Transparent"
                                                       SvgImageToggleButton_ImageColor="{StaticResource OtherSide_DarkGray}"
                                                       BorderThickness="0"/>

                  <ContentPresenter Grid.Row="0" Grid.Column="1" 
                                    x:Name="PART_Header"
                                    ContentSource="Header"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="Center" />

                  <ItemsPresenter Grid.Row="1" Grid.Column="1" x:Name="ItemsHost"/>
               </Grid>

               <ControlTemplate.Triggers>
                  <Trigger Property="IsExpanded" Value="false">
                     <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                  </Trigger>
                  <Trigger Property="IsExpanded" Value="true">
                     <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                  </Trigger>
                  <DataTrigger Binding="{Binding HasItems, RelativeSource={RelativeSource Self}}" Value="False">
                     <Setter TargetName="ExpanderToggleButton" Property="Visibility" Value="Collapsed" />
                  </DataTrigger>                  
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type Border}" x:Key="DomainObjectTreeViewSelectableBorder">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightLightGray}" />
      <Style.Triggers>
         <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{StaticResource OtherSide_SuperLightGray}" />
            <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" />
         </Trigger>
         <DataTrigger Binding="{Binding IsSelected}" Value="True">
            <Setter Property="Background" Value="{Binding Path=(extensions:TreeViewExtension.TreeViewSelectedItemBackgroundColor), RelativeSource={RelativeSource AncestorType={x:Type TreeView}}}" />
            <Setter Property="BorderBrush" Value="Transparent" />
         </DataTrigger>
         <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
               <Condition Binding="{Binding DataContext.IsSelectionLocked, Mode=OneWay, RelativeSource={RelativeSource AncestorType={x:Type TreeView}}}" Value="True" />
               <Condition Binding="{Binding IsSelected}" Value="True" />
            </MultiDataTrigger.Conditions>
            <MultiDataTrigger.Setters>
               <Setter Property="Background" Value="{StaticResource Locked_Red}" />
               <Setter Property="BorderBrush" Value="Transparent" />
            </MultiDataTrigger.Setters>
         </MultiDataTrigger>
      </Style.Triggers>
   </Style>
   
  <!-- Button Link -->
   <Style TargetType="{x:Type Button}" x:Key="LinkButton">
      <Setter Property="Foreground" Value="Black" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="Button">

               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <ContentPresenter Grid.Row="0" 
                                    Content="{TemplateBinding Content}" 
                                    TextBlock.Foreground="{TemplateBinding Foreground}" 
                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}" 
                                    VerticalAlignment="{TemplateBinding VerticalAlignment}" 
                                    TextBlock.FontWeight="{TemplateBinding FontWeight}"/>

                  <Border x:Name="Border"
                          Grid.Row="1"
                          BorderThickness="0,1,0,0"
                          BorderBrush="{TemplateBinding Foreground}" />
               </Grid>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsEnabled" Value="False">
                     <Setter Property="Opacity" Value="0.3" TargetName="Border" />
                  </Trigger>
               </ControlTemplate.Triggers>

            </ControlTemplate>
         </Setter.Value>
      </Setter>
      
   </Style>

   <Style TargetType="{x:Type ToggleButton}" x:Key="LinkToggleButton">
      <Setter Property="Foreground" Value="Black" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">

               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <ContentPresenter Grid.Row="0" 
                                    Content="{TemplateBinding Content}" 
                                    TextBlock.Foreground="{TemplateBinding Foreground}" 
                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}" 
                                    VerticalAlignment="{TemplateBinding VerticalAlignment}" 
                                    TextBlock.FontWeight="{TemplateBinding FontWeight}"/>

                  <Border x:Name="Border"
                       Grid.Row="1"
                       BorderThickness="0,1,0,0"
                       BorderBrush="{TemplateBinding Foreground}" />
               </Grid>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsEnabled" Value="False">
                     <Setter Property="Opacity" Value="0.3" TargetName="Border" />
                  </Trigger>
               </ControlTemplate.Triggers>

            </ControlTemplate>
         </Setter.Value>
      </Setter>

   </Style>

   <!-- Tree view node grid style -->
   <Style TargetType="{x:Type Grid}" x:Key="TreeViewNodeGridStyle">
      <Setter Property="MinHeight" Value="28" />
   </Style>
   
   <!-- SingleDomainObject default style-->
   <Style TargetType="{x:Type browser:SingleDomainObjectBrowser}">
      <Setter Property="SingleDomainObjectBrowser_CreateCommand" Value="{Binding BrowserViewModel.CreateAsyncCommand}" />
      <Setter Property="SingleDomainObjectBrowser_DeleteCommand" Value="{Binding BrowserViewModel.SelectedDomainObjectEditorViewModel.DeleteAsyncCommand}" />
      <Setter Property="SingleDomainObjectBrowser_Name" Value="{Binding WorkspaceDescription.Name}" />
      <Setter Property="SingleDomainObjectBrowser_IconGeometry" Value="{Binding WorkspaceDescription.IconResource}" />
   </Style> 
   
   <!-- Button Separator border-->
   <Style TargetType="{x:Type Border}" x:Key="ButtonSeparatorBorder">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1,0,0,0" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_Gray}" />
      <Setter Property="Height" Value="24" />
   </Style>

   <Style TargetType="{x:Type ToggleButton}" x:Key="TextExpanderHeaderToggleButton">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type ToggleButton}">
               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto" />
                     <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <ContentPresenter Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Height="{TemplateBinding Height}" />

                  <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                     <customControls:SvgImageToggleButton SvgImageToggleButton_IconGeometry="{StaticResource icon_chevron-right}" 
                                                          SvgImageToggleButton_CheckedIconGeometry="{StaticResource icon_chevron-down}"
                                                          SvgImageToggleButton_CheckedBackgroundColor="Transparent"
                                                          SvgImageToggleButton_OverBackgroundColor="Transparent"
                                                          SvgImageToggleButton_ImageSize="20"
                                                          BorderThickness="0"
                                                          Height="{TemplateBinding Height}"
                                                          Margin="2,4,0,0"
                                                          IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}"/>
                  </Grid>

                  <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="1" BorderThickness="0" BorderBrush="{StaticResource OtherSide_DarkGray}" />

               </Grid>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <!-- Constraint Text Radio Button -->
   <Style TargetType="{x:Type customControls:TextRadioButton}" x:Key="ConstraintTextRadioButton">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type RadioButton}">
               <StackPanel Background="Transparent">
                  <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TextRadioButton_Text}" 
                          FontWeight="DemiBold"
                          Foreground="Black"
                          HorizontalAlignment="Center"
                          x:Name="ConstraintName"/>
                  <Border Height="2" 
                       SnapsToDevicePixels="True" 
                       Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TextRadioButton_SelectedColor}" 
                       Margin="0,3,0,0"
              x:Name="UnderlineBorder" Visibility="Hidden"/>
               </StackPanel>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsChecked" Value="True">
                     <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TextRadioButton_SelectedColor}" TargetName="ConstraintName" />
                     <Setter Property="Visibility" Value="Visible" TargetName="UnderlineBorder" />
                     <Setter Property="FontWeight" Value="Bold" TargetName="ConstraintName" />
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>

         </Setter.Value>
      </Setter>
   </Style>

   <!-- Details Editor Panel Category -->
   <Style TargetType="{x:Type customControls:InfoPanelCategory}" x:Key="DetailsEditorPanelCategory">
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type customControls:InfoPanelCategory}">

               <Border Style="{StaticResource DetailsEditorNodeBorderStyle}">

                  <Grid>
                     <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                     </Grid.RowDefinitions>

                     <ToggleButton x:Name="HeaderToggleButton"
                                   Margin="4,0,0,0"
                                   Style="{StaticResource DetailsEditorHeaderToggleButton}"
                                   IsChecked="{Binding InfoPanelCategory_IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type customControls:InfoPanelCategory}}}"
                                   Content="{Binding InfoPanelCategory_HeaderName, RelativeSource={RelativeSource AncestorType={x:Type customControls:InfoPanelCategory}}}"/>

                     <ContentPresenter Grid.Row="1" Margin="0,8,0,0"
                                        Visibility="{Binding IsChecked, ElementName=HeaderToggleButton, Converter={StaticResource BoolToVisibleOrCollapsed}}" />

                  </Grid>

               </Border>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

</ResourceDictionary>