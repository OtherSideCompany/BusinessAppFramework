                           <ColumnDefinition Width="*" />
                           <ColumnDefinition Width="Auto" />
                           <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding Text, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 Foreground="{TemplateBinding Foreground}"
                                 x:Name="InnerTextBox"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>

                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding ClickSelectSearchTextBox_Watermark, RelativeSource={RelativeSource TemplatedParent}}"
                                   Foreground="{StaticResource OtherSide_Gray}"
                                   IsHitTestVisible="False"
                                   x:Name="UserMessage"
                                   Visibility="Hidden"/>

                        <TextBlock Grid.Column="1" Margin="4,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding ClickSelectSearchTextBox_Units, RelativeSource={RelativeSource TemplatedParent}}"
                                   Foreground="{StaticResource OtherSide_Gray}"
                                   IsHitTestVisible="False"/>                        

                     </Grid>

                     <customControls:SvgImageButton Grid.Column="1" Margin="2"
                                                    Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                                                    BorderThickness="0"
                                                    SvgImageButton_IconGeometry="{StaticResource icon_magnify}"
                                                    SvgImageButton_ImageSize="20"
                                                    Command="{Binding ClickSelectSearchTextBox_SearchCommand, RelativeSource={RelativeSource TemplatedParent}}" 
                                                    IsEnabled="{Binding ClickSelectSearchTextBox_CanSearch, RelativeSource={RelativeSource TemplatedParent}}"/>

                  </Grid>
               </Border>

               <ControlTemplate.Triggers>
                  <MultiTrigger>
                     <MultiTrigger.Conditions>
                        <Condition Property="Text" Value=""/>
                        <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                     </MultiTrigger.Conditions>
                     <Setter Property="Visibility" TargetName="UserMessage" Value="Visible"/>
                  </MultiTrigger>
                  <MultiTrigger>
                     <MultiTrigger.Conditions>
                        <Condition Property="Text" Value=""/>
                        <Condition Property="IsReadOnly" Value="True"/>
                     </MultiTrigger.Conditions>
                     <Setter Property="Visibility" TargetName="UserMessage" Value="Visible"/>
                  </MultiTrigger>
                  <Trigger Property="IsKeyboardFocusWithin" Value="True">
                     <Setter TargetName="InnerTextBox" Property="FocusManager.FocusedElement" Value="{Binding ElementName=InnerTextBox}" />
                  </Trigger>
                  <MultiTrigger>
                     <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsReadOnly" Value="False"/>
                        <Condition Property="ClickSelectSearchTextBox_IsInputValid" Value="True"/>
                     </MultiTrigger.Conditions>
                     <Setter Property="BorderBrush" Value="{StaticResource OtherSide_Gray}" TargetName="Border"/>
                  </MultiTrigger>
                  <Trigger Property="IsEnabled" Value="False">
                     <Setter Property="Opacity" Value="0.5" TargetName="InnerTextBox" />
                  </Trigger>
                  <Trigger Property="IsReadOnly" Value="True">
                     <Setter Property="Foreground" Value="{StaticResource OtherSide_DarkGray}"/>
                  </Trigger>
                  <Trigger Property="ClickSelectSearchTextBox_IsInputValid" Value="False">
                     <Setter Property="Foreground" Value="{StaticResource OtherSide_Red}"/>
                     <Setter Property="BorderBrush" Value="{StaticResource OtherSide_Red}"/>
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
      <Style.Triggers>
         <Trigger Property="IsReadOnly" Value="True">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Arrow" />
         </Trigger>
      </Style.Triggers>
   </Style>

