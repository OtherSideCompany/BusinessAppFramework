<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"                    
                    x:Class="OtherSideCore.Wpf.CustomControls.Style"
                    xmlns:userControls="clr-namespace:OtherSideCore.Wpf.UserControls"
                    xmlns:customControls="clr-namespace:OtherSideCore.Wpf.CustomControls"
                    xmlns:extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
                    xmlns:behaviors="clr-namespace:OtherSideCore.Wpf.Behavior;assembly=OtherSideCore.Wpf"
                    xmlns:browser="clr-namespace:OtherSideCore.Wpf.UserControls.Browser">

   <ResourceDictionary.MergedDictionaries>
      <ResourceDictionary Source="pack://application:,,,/OtherSideCore.Wpf;component/Icons/Icons.xaml"/>
   </ResourceDictionary.MergedDictionaries>

   <!-- Colors -->
   <SolidColorBrush Color="#FF6c6c6c" x:Key="OtherSide_DarkGray"/>
   <SolidColorBrush Color="#FFa9a9a9" x:Key="OtherSide_Gray"/>
   <SolidColorBrush Color="#FFE6E6E6" x:Key="OtherSide_LightGray"/>
   <SolidColorBrush Color="#FFE6E6E6" x:Key="OtherSide_LightLightGray" Opacity="0.5"/>
   <SolidColorBrush Color="#FFE6E6E6" x:Key="OtherSide_SuperLightGray" Opacity="0.2"/>

   <SolidColorBrush Color="#FFf75367" x:Key="OtherSide_Red_Light"/>
   <SolidColorBrush Color="#FFee001c" x:Key="OtherSide_Red"/>
   <SolidColorBrush Color="#FFb20015" x:Key="OtherSide_Red_Dark"/>

   <SolidColorBrush Color="#FF0bc136" x:Key="OtherSide_Green" />
   <SolidColorBrush Color="#FF078024" x:Key="OtherSide_Green_Dark" />

   <SolidColorBrush Color="#FFFFEF00" x:Key="OtherSide_Yellow" />

   <SolidColorBrush Color="#ff1789fc" x:Key="Highlight_Blue" />

   <SolidColorBrush Color="#FFc90219" x:Key="Locked_Red" Opacity="0.3"/>  

   <!-- default textblock -->
   <Style TargetType="{x:Type TextBlock}">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Style.Triggers>
         <Trigger Property="IsEnabled" Value="False" >
            <Setter Property="Opacity" Value="0.3"></Setter>
         </Trigger>
      </Style.Triggers>
   </Style>

   <!-- main grid application layout style -->
   <Style TargetType="{x:Type Grid}" x:Key="MainGridApplicationLayout">
      <Setter Property="Margin" Value="0" />
      <Style.Triggers>
         <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
            <Setter Property="Margin" Value="7" />
         </DataTrigger>
      </Style.Triggers>
   </Style>

   <!-- Ribon border style -->
   <Style TargetType="{x:Type Border}" x:Key="RibonBorderStyle">
      <Setter Property="Height" Value="32" />
      <Setter Property="Background" Value="Transparent" />
   </Style>

   <!-- OtherSideCoreListView style-->
   <Style TargetType="{x:Type Thumb}" x:Key="GridViewThumbStyle">
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type Thumb}">
               <Border Background="Transparent" Width="20" x:Name="ParentBorder">
                  <Border Width="2" 
                          HorizontalAlignment="Right" 
                          Background="{Binding Path=(extensions:ListViewExtension.ThumbColor), RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" 
                          x:Name="Splitter" 
                          Visibility="Hidden"/>                  
               </Border>
               <ControlTemplate.Triggers>
                  <Trigger SourceName="ParentBorder" Property="IsMouseOver" Value="True">
                     <Setter TargetName="Splitter" Property="Visibility" Value="Visible"></Setter>
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type GridViewColumnHeader}" x:Key="GridViewColumnHeaderContainerStyle">
      <Setter Property="VerticalContentAlignment" Value="Bottom" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Foreground" Value="{Binding Path=(extensions:ListViewExtension.HeaderForegroundColor), RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" />
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="MinWidth" Value="50" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
               <Grid Background="{TemplateBinding Background}">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="*" />
                     <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <ContentPresenter x:Name="HeaderContent" Margin="10,10,0,5"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                     <ContentPresenter.Resources>
                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                           <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                           <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                           <Setter Property="LineHeight" Value="16" />
                        </Style>
                     </ContentPresenter.Resources>
                  </ContentPresenter>

                  <Thumb Grid.Column="1" x:Name="PART_HeaderGripper" HorizontalAlignment="Right" DragDelta="GridViewColumnHeader_ThumbDragDelta" 
                         Style="{StaticResource GridViewThumbStyle}" />
               </Grid>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Background" Value="{StaticResource OtherSide_LightLightGray}" />
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type GridViewColumnHeader}" x:Key="SortableGridViewColumnHeaderContainerStyle">
      <Setter Property="VerticalContentAlignment" Value="Bottom" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Foreground" Value="{Binding Path=(extensions:ListViewExtension.HeaderForegroundColor), RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" />
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="MinWidth" Value="50" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
               
               <Grid Background="{TemplateBinding Background}">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="*" />
                     <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Border x:Name="HeaderBorder"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                     <Grid Margin="4,8,0,8">
                        <Grid.ColumnDefinitions>
                           <ColumnDefinition Width="Auto" />
                           <ColumnDefinition Width="Auto" />
                           <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Visibility="{Binding Column.IsSorted, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibleOrCollapsed}, FallbackValue=Collapsed}">

                           <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                              <Canvas Width="24" Height="24" Background="Transparent">
                                 <Path Fill="{TemplateBinding Foreground}">
                                    <Path.Style>
                                       <Style TargetType="{x:Type Path}">
                                          <Style.Setters>
                                             <Setter Property="Data" Value="{StaticResource icon_arrow-down-thin}" />
                                          </Style.Setters>
                                          <Style.Triggers>
                                             <DataTrigger Binding="{Binding Column.SortDirection, RelativeSource={RelativeSource TemplatedParent}}" Value="1">
                                                <Setter Property="Data" Value="{StaticResource icon_arrow-up-thin}" />
                                             </DataTrigger>
                                          </Style.Triggers>
                                       </Style>
                                    </Path.Style>
                                 </Path>
                              </Canvas>
                           </Viewbox>

                        </Grid>

                        <Border Grid.Column="1" Width="5" Background="Transparent" 
                                Visibility="{Binding Column.IsSorted, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=invert}"/>

                        <ContentPresenter Grid.Column="2" x:Name="HeaderContent"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                           <ContentPresenter.Resources>
                              <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                 <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                                 <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                                 <Setter Property="LineHeight" Value="16" />
                                 <Setter Property="Margin" Value="0,0,0,0" />
                              </Style>
                           </ContentPresenter.Resources>
                        </ContentPresenter>

                     </Grid>
                  </Border>

                  <Border Grid.Column="1"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
                     <Thumb x:Name="PART_HeaderGripper" HorizontalAlignment="Right" 
                            DragDelta="GridViewColumnHeader_ThumbDragDelta" 
                            Style="{StaticResource GridViewThumbStyle}" />
                  </Border>

               </Grid>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Background" Value="{StaticResource OtherSide_SuperLightGray}" />
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type ListViewItem}" x:Key="ListViewItemContainerStyle" >
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightLightGray}" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Foreground" Value="Black" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType='{x:Type ListViewItem}'>
               <Border Background="{TemplateBinding Background}" 
                       BorderThickness="{TemplateBinding BorderThickness}" 
                       BorderBrush="{TemplateBinding BorderBrush}">
                  <GridViewRowPresenter Content="{TemplateBinding Content}" Margin="6,0,0,0"
                                        Columns="{TemplateBinding GridView.ColumnCollection}"/>
               </Border>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
      <Style.Triggers>
         <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{StaticResource OtherSide_SuperLightGray}" />
         </Trigger>
      </Style.Triggers>
   </Style>

   <Style TargetType="{x:Type ListView}" x:Key="OtherSideCoreListView">
      <Style.Resources>
         <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource GridViewColumnHeaderContainerStyle}" />
      </Style.Resources>

      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ItemContainerStyle" Value="{StaticResource ListViewItemContainerStyle}" />
      <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
      <EventSetter Event="PreviewMouseWheel" Handler="ListView_PreviewMouseWheel" />

   </Style>  

   <!-- DomainObjectSearch List View-->
   <Style TargetType="{x:Type ListViewItem}" x:Key="DomainObjectSearchListViewItemContainerStyle" BasedOn="{StaticResource ListViewItemContainerStyle}">
      <Style.Triggers>
         <DataTrigger Binding="{Binding IsSelected}" Value="True">
            <Setter Property="Background" Value="{Binding Path=(extensions:ListViewExtension.SelectedItemBackgroundColor), RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" />
         </DataTrigger>
         <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
               <Condition Binding="{Binding DataContext.IsSelectionLocked, Mode=OneWay, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" Value="True" />
               <Condition Binding="{Binding IsSelected}" Value="True" />
            </MultiDataTrigger.Conditions>
            <MultiDataTrigger.Setters>
               <Setter Property="Background" Value="{StaticResource Locked_Red}" />
            </MultiDataTrigger.Setters>
         </MultiDataTrigger>
      </Style.Triggers>
   </Style>

   <Style TargetType="{x:Type GridViewColumnHeader}" x:Key="DomainObjectSearchColumnHeader" BasedOn="{StaticResource SortableGridViewColumnHeaderContainerStyle}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightLightGray}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Foreground" Value="{StaticResource OtherSide_Gray}" />
   </Style>

   <Style TargetType="{x:Type ListView}" x:Key="DomainObjectSearchListView" BasedOn="{StaticResource OtherSideCoreListView}">
      <Style.Resources>
         <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource DomainObjectSearchColumnHeader}" />
      </Style.Resources>

      <Setter Property="Background" Value="Transparent" />
      <Setter Property="ItemContainerStyle" Value="{StaticResource DomainObjectSearchListViewItemContainerStyle}" />
      <EventSetter Event="PreviewMouseLeftButtonUp" Handler="DomainObjectSearchListView_PreviewMouseLeftButtonUp" />
      <EventSetter Event="MouseDoubleClick" Handler="DomainObjectSearchListView_MouseDoubleClick" />
   </Style>
   
   <!-- Data Grid -->

   <Style x:Key="DataGridColumnHeaderGripperStyle" TargetType="{x:Type Thumb}">
      <Setter Property="Cursor" Value="SizeWE" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type Thumb}">

               <Border Background="{StaticResource OtherSide_SuperLightGray}" Width="20" x:Name="ParentBorder"
                       BorderBrush="{StaticResource OtherSide_LightGray}"
                       BorderThickness="0,0,1,0">
                  <Border Width="2" 
                          HorizontalAlignment="{TemplateBinding HorizontalAlignment}" 
                          Background="{Binding Path=(extensions:DataGridExtension.ThumbColor), RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}" 
                          x:Name="Splitter" 
                          Visibility="Hidden"/>
               </Border>
               <ControlTemplate.Triggers>
                  <Trigger SourceName="ParentBorder" Property="IsMouseOver" Value="True">
                     <Setter TargetName="Splitter" Property="Visibility" Value="Visible"></Setter>
                  </Trigger>
               </ControlTemplate.Triggers>

            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type DataGridColumnHeader}" x:Key="DataGridColumnHeaderStyle">
      <Setter Property="VerticalContentAlignment" Value="Bottom" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="Foreground" Value="{StaticResource OtherSide_Gray}" />
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="MinWidth" Value="50" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">

               <Grid Background="{TemplateBinding Background}">
                  <Grid.ColumnDefinitions>
                     <ColumnDefinition Width="Auto" />
                     <ColumnDefinition Width="*" />
                     <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Border Grid.Column="1" 
                          x:Name="columnHeaderBorder"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          Padding="3,0,3,0"
                          Background="{StaticResource OtherSide_SuperLightGray}">
                     <ContentPresenter Margin="4,10,4,5" 
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                        <ContentPresenter.Resources>
                           <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                              <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                              <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
                              <Setter Property="LineHeight" Value="16" />
                              <Setter Property="Margin" Value="0,0,0,0" />
                           </Style>
                        </ContentPresenter.Resources>
                     </ContentPresenter>
                  </Border>

                  <Thumb Grid.Column="2" x:Name="PART_RightHeaderGripper"
                         Style="{StaticResource DataGridColumnHeaderGripperStyle}" 
                         HorizontalAlignment="Right"/>                  
               </Grid>

               <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Background" Value="{StaticResource OtherSide_SuperLightGray}" />
                  </Trigger>
               </ControlTemplate.Triggers>

            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <Style TargetType="{x:Type DataGridCell}" x:Key="OtherSideDataGridCell">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type DataGridCell}">
               <Border BorderBrush="{StaticResource OtherSide_LightGray}"
                       Padding="4"
                       Background="{TemplateBinding Background}">
                  <Border Background="Transparent"
                          SnapsToDevicePixels="True"
                          VerticalAlignment="Center">
                     <ContentPresenter HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       SnapsToDevicePixels="True" />
                  </Border>
               </Border>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
      <Style.Triggers>
         <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="{StaticResource OtherSide_SuperLightGray}" />
            <Setter Property="Foreground" Value="Black" />
         </Trigger>
      </Style.Triggers>
   </Style>

   <Style TargetType="{x:Type DataGrid}" x:Key="OtherSideCoreDataGrid">

      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="BorderThickness" Value="1,1,1,0" />

      <Setter Property="ColumnHeaderStyle" Value="{StaticResource DataGridColumnHeaderStyle}" />
      <Setter Property="CellStyle" Value="{StaticResource OtherSideDataGridCell}" />

      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CanUserResizeRows" Value="False" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="SelectionUnit" Value="Cell" />

      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="VerticalGridLinesBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="GridLinesVisibility" Value="All" />

      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
      <EventSetter Event="PreviewMouseWheel" Handler="ListView_PreviewMouseWheel" />

   </Style>


   <!-- Separator border -->
   <Style x:Key="SeparatorBorder" TargetType="{x:Type Border}">
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="15,0,15,0" />
   </Style>

   <!-- Panel Header Label -->
   <Style TargetType="{x:Type Label}" x:Key="PanelHeaderLabel">
      <Setter Property="Height" Value="32"/>
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type Label}">
               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="{TemplateBinding Height}" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <ContentPresenter Grid.Row="0" />
                  <Border Grid.Row="1" Style="{StaticResource SeparatorBorder}" Margin="0" />
               </Grid>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <!-- Vertical Module Splitter -->
   <Style TargetType="{x:Type GridSplitter}" x:Key="VerticalModuleGridSplitter">
      <Setter Property="Width" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="ResizeDirection" Value="Columns" />
      <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type GridSplitter}">
               <Grid>
                  <Border Background="{TemplateBinding Background}">
                     <Border Background="Transparent" Width="1" x:Name="Indicator" HorizontalAlignment="{TemplateBinding HorizontalAlignment}" />
                  </Border>
               </Grid>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Background" Value="{StaticResource OtherSide_Gray}" TargetName="Indicator" />
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <!-- Horizontal Module Splitter -->
   <Style TargetType="{x:Type GridSplitter}" x:Key="HorizontalModuleGridSplitter">
      <Setter Property="Height" Value="10" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="ResizeDirection" Value="Rows" />
      <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="{x:Type GridSplitter}">
               <Grid>
                  <Border Background="{TemplateBinding Background}">
                     <Border Background="{StaticResource OtherSide_LightGray}" Height="1" Margin="10,0,10,0" />
                  </Border>
               </Grid>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <!-- Property label style -->
   <Style x:Key="PropertyLabelTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
      <Setter Property="Foreground" Value="Gray" />
      <Setter Property="Margin" Value="0,0,24,0" />
   </Style>

   <Style x:Key="VerticalPropertyLabelTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
      <Setter Property="Foreground" Value="Gray" />
      <Setter Property="Margin" Value="4,4,0,0" />
   </Style>

   <Style x:Key="PropertyLabelWithHelperTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource PropertyLabelTextBlock}">
      <Setter Property="Cursor" Value="Help" />
   </Style>

   <!-- Borderless Text Box -->
   <Style TargetType="{x:Type TextBox}" x:Key="BorderlessTextbox">
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate>
               <Border Background="{TemplateBinding Background}" x:Name="Bd">
                  <ScrollViewer x:Name="PART_ContentHost" />
               </Border>
               <ControlTemplate.Triggers>
                  <Trigger Property="IsEnabled" Value="False">
                     <Setter Property="Opacity" Value="0.3" />
                  </Trigger>
               </ControlTemplate.Triggers>
            </ControlTemplate>
         </Setter.Value>
      </Setter>
   </Style>

   <!-- Repository Editor List View Pannel -->
   <Style x:Key="WorkspaceBorder" TargetType="{x:Type Border}">
      <Setter Property="Margin" Value="24,16,0,4" />
   </Style>

   <!-- Model Object Properties Pannel -->
   <Style x:Key="DomainObjectPropertiesPannel" TargetType="{x:Type Border}">
      <Setter Property="MinWidth" Value="100" />
      <Setter Property="BorderBrush" Value="#ededed" />
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="SnapsToDevicePixels" Value="True" />
   </Style>

   <Style x:Key="DomainObectPropertiesHeader" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource OtherSide_DarkGray}" />
      <Setter Property="Margin" Value="16,16,0,16" />
   </Style>

   <!-- View header -->
   <Style x:Key="ViewHeader" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
   </Style>

   <!-- databasefield edition border -->
   <Style x:Key="EditableTextBoxBorder" TargetType="{x:Type Border}">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Margin" Value="0,4,0,4" />
      <Setter Property="Height" Value="32" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="CornerRadius" Value="8" />
      <Style.Triggers>
         <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="BorderBrush" Value="{StaticResource OtherSide_Gray}" />
         </Trigger>
      </Style.Triggers>
   </Style>

   <!-- ClickSelectTextBox -->
   <Style TargetType="{x:Type customControls:ClickSelectTextBox}">
      <Setter Property="Background" Value="White" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" />
      <Setter Property="Template">
         <Setter.Value>
            <ControlTemplate TargetType="customControls:ClickSelectTextBox">

               <Border BorderThickness="{TemplateBinding BorderThickness}"
                       BorderBrush="{TemplateBinding BorderBrush}"                       
                       Background="{TemplateBinding Background}"
                       CornerRadius="8"
                       x:Name="Border">
                  <Grid Margin="{Binding ClickSelectTextBox_TextMargin, RelativeSource={RelativeSource TemplatedParent}}" 
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                     </Grid.ColumnDefinitions>
                     
                     <TextBox Text="{Binding Text, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}" 
                              Background="Transparent"
                              BorderThickness="0"
                              VerticalAlignment="Center"
                              Foreground="{TemplateBinding Foreground}"
                              x:Name="InnerTextBox"
                              IsReadOnly="{TemplateBinding IsReadOnly}"/>
                     
                     <TextBlock VerticalAlignment="Center"
                                Text="{Binding ClickSelectTextBox_Watermark, RelativeSource={RelativeSource TemplatedParent}}"
                                Foreground="{StaticResource OtherSide_Gray}"
                                IsHitTestVisible="False"
                                x:Name="UserMessage"
                                Visibility="Hidden"/>

                     <TextBlock Grid.Column="1" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Text="{Binding ClickSelectTextBox_Units, RelativeSource={RelativeSource TemplatedParent}}"
                                Foreground="{StaticResource OtherSide_Gray}"
                                IsHitTestVisible="False"/>

                  </Grid>
               </Border>

               <ControlTemplate.Triggers>
                  <MultiTrigger>
                     <MultiTrigger.Conditions>
                        <Condition Property="Text" Value=""/>
