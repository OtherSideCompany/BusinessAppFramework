<UserControl x:Class="OtherSideCore.Wpf.UserControls.Files.FileTypeIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Files"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="FileTypeIconUserControl">
    <Grid>
      <osc_customcontrols:SvgViewer SvgViewer_ImageHeight="24"
                                    SvgViewer_ImageColor="{Binding FileTypeIcon_FileIconColor, ElementName=FileTypeIconUserControl}">
         <osc_customcontrols:SvgViewer.Style>
            <Style TargetType="{x:Type osc_customcontrols:SvgViewer}" BasedOn="{StaticResource {x:Type osc_customcontrols:SvgViewer}}">
               <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-outline}" />
               <Style.Triggers>
                  <DataTrigger Binding="{Binding}" Value=".pdf">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_pdf-file}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".jpg">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".jpeg">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".png">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".gif">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".bmp">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".tiff">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding}" Value=".webp">
                     <Setter Property="SvgViewer_ImageGeometry" Value="{StaticResource icon_file-image-outline}" />
                  </DataTrigger>
               </Style.Triggers>
            </Style>
         </osc_customcontrols:SvgViewer.Style>

      </osc_customcontrols:SvgViewer>
    </Grid>
</UserControl>
