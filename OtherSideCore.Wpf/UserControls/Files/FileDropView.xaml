<UserControl x:Class="OtherSideCore.Wpf.UserControls.Files.FileDropView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Files"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="FileDropViewUserControl">
   <Grid AllowDrop="True" 
         Background="Transparent"
         Drop="DropFileGrid_Drop"
         DragEnter="DropFileGrid_DragEnter"
         DragLeave="DropFileGrid_DragLeave">

      <Rectangle>
         <Rectangle.Style>
            <Style TargetType="{x:Type Rectangle}">
               <Setter Property="Stroke" Value="{StaticResource OtherSide_LightGray}" />
               <Setter Property="StrokeThickness" Value="2" />
               <Setter Property="StrokeDashArray" Value="3 2" />
               <Setter Property="SnapsToDevicePixels" Value="True" />
               <Setter Property="RadiusX" Value="4" />
               <Setter Property="RadiusY" Value="4" />
               <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFileOvered, Mode=OneWay, ElementName=FileDropViewUserControl}" Value="True">
                     <Setter Property="Stroke" Value="{Binding FileDropUserControl_OverBorderColor, ElementName=FileDropViewUserControl}" />
                  </DataTrigger>
               </Style.Triggers>
            </Style>
         </Rectangle.Style>
      </Rectangle>

      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal" Margin="8">

         <osc_customcontrols:SvgViewer SvgViewer_ImageGeometry="{StaticResource icon_upload}"
                                       SvgViewer_ImageColor="{Binding FileDropUserControl_IconColor, ElementName=FileDropViewUserControl}"
                                       SvgViewer_ImageHeight="16" />

         <TextBlock Text="Déposez vos fichiers à transférer" TextWrapping="Wrap" TextAlignment="Center"/>

      </StackPanel>

   </Grid>
</UserControl>
