<UserControl x:Class="OtherSideCore.Wpf.UserControls.Modules.ModuleHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Modules"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="ModuleHeaderUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Width="32" Height="32" 
              Background="{Binding ModuleHeader_Foreground, ElementName=ModuleHeaderUserControl}" 
              CornerRadius="16">

         <osc_customcontrols:SvgViewer SvgViewer_ImageColor="White"
                                       SvgViewer_ImageHeight="20"
                                       SvgViewer_ImageGeometry="{Binding ModuleHeader_IconGeometry, ElementName=ModuleHeaderUserControl}"/>

      </Border>

      <TextBlock Grid.Column="1" 
                 Text="{Binding ModuleHeader_Name, ElementName=ModuleHeaderUserControl}"
                 Style="{StaticResource ViewHeader}" 
                 Margin="8,0,0,0" 
                 VerticalAlignment="Center" 
                 Foreground="{Binding ModuleHeader_Foreground, ElementName=ModuleHeaderUserControl}" />

      <TextBlock Grid.Column="2" 
                 Text="*"
                 Style="{StaticResource ViewHeader}" 
                 Margin="4,0,0,0" 
                 VerticalAlignment="Center" 
                 Foreground="{Binding ModuleHeader_Foreground, ElementName=ModuleHeaderUserControl}" 
                 Visibility="{Binding ModuleHeader_HasUnsavedChanges, ElementName=ModuleHeaderUserControl, Converter={StaticResource BoolToVisibleOrCollapsed}}"/>
   </Grid>
</UserControl>
