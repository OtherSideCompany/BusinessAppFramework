<UserControl x:Class="OtherSideCore.Wpf.UserControls.Tree.TreeViewNode"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Tree"
                xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
                xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
                xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
                mc:Ignorable="d" 
                d:DesignHeight="450" d:DesignWidth="800"
                x:Name="TreeViewNodeUserControl">
   <Grid PreviewMouseLeftButtonUp="Grid_PreviewMouseLeftButtonUp">
      <Border CornerRadius="8" Margin="0,4,0,4" 
              Style="{StaticResource DomainObjectTreeViewSelectableBorder}">
         <ContentControl Content="{Binding TreeViewNode_Content, ElementName=TreeViewNodeUserControl}" />
      </Border>
   </Grid>
</UserControl>
