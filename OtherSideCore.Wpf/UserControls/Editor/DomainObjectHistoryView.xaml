<UserControl x:Class="OtherSideCore.Wpf.UserControls.Editor.DomainObjectHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Editor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="Auto" />
         <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Column="0" Grid.Row="0" Style="{StaticResource PropertyLabelTextBlock}" Text="Création" />
      <TextBlock Grid.Column="0" Grid.Row="1" Style="{StaticResource PropertyLabelTextBlock}" Text="Dernière modification" />

      <Border Grid.Row="0" Grid.Column="1" Height="32" >
         <TextBlock Text="{Binding CreationDescription, Mode=OneWay}" Style="{StaticResource TrackingInfosClickSelectTextBlock}" />
      </Border>

      <Border Grid.Row="1" Grid.Column="1" Height="32" >
         <TextBlock Text="{Binding ModificationDescription, Mode=OneWay}" Style="{StaticResource TrackingInfosClickSelectTextBlock}" />
      </Border>

   </Grid>
</UserControl>
