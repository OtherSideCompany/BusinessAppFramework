<UserControl x:Class="OtherSideCore.Wpf.UserControls.Workflows.ProcessWorkflowHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OtherSideCore.Wpf.UserControls.Workflows"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions" xmlns:list="clr-namespace:OtherSideCore.Wpf.UserControls.List"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="ProcessWorkflowHeaderUserControl">
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*" />
         <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <ItemsControl ItemsSource="{Binding ProcessWorkflowStepViewModels}">
         <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
               <UniformGrid Columns="{Binding ProcessWorkflowStepViewModels.Count}" />
            </ItemsPanelTemplate>
         </ItemsControl.ItemsPanel>
         <ItemsControl.ItemTemplate>
            <DataTemplate>

               <Border BorderThickness="0">

                  <Grid>
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                     </Grid.ColumnDefinitions>
                     <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                     </Grid.RowDefinitions>

                     <Border Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Height="2">
                        <Border.Style>
                           <Style TargetType="{x:Type Border}">
                              <Setter Property="Background" Value="{StaticResource OtherSide_LightGray}" />
                              <Style.Triggers>
                                 <DataTrigger Binding="{Binding IsPreviousStepCompleted}" Value="True">
                                    <Setter Property="Background" Value="{Binding ProcessWorkflowHeader_CompletedColor, ElementName=ProcessWorkflowHeaderUserControl}" />
                                 </DataTrigger>
                              </Style.Triggers>
                           </Style>
                        </Border.Style>
                     </Border>

                     <Button Cursor="Hand" Grid.Row="0" Grid.Column="1"
                             Command="{Binding DataContext.GoToStepCommand, ElementName=ProcessWorkflowHeaderUserControl}"
                             CommandParameter="{Binding}">
                        <Button.Style>
                           <Style TargetType="{x:Type Button}">
                              <Setter Property="Template">
                                 <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                       <Grid>

                                          <Border Width="20" Height="20" 
                                                  CornerRadius="12"
                                                  BorderThickness="3"
                                                  BorderBrush="{StaticResource OtherSide_Gray}"
                                                  Background="Transparent" 
                                                  x:Name="OuterBorder"/>

                                          <Ellipse Width="8" Height="8" 
                                                   Fill="{Binding ProcessWorkflowHeader_SelectedColor, ElementName=ProcessWorkflowHeaderUserControl}"
                                                   x:Name="InnerEllipse"
                                                   Visibility="Collapsed" />

                                          <osc_customcontrols:SvgViewer Width="16" Height="16"
                                                                        SvgViewer_ImageColor="White"
                                                                        SvgViewer_ImageGeometry="{StaticResource icon_check}" 
                                                                        SvgViewer_ImageHeight="16"
                                                                        x:Name="CheckImage"
                                                                        Visibility="Collapsed"/>

                                       </Grid>
                                       <ControlTemplate.Triggers>
                                          <DataTrigger Binding="{Binding IsExecutable}" Value="False">
                                             <Setter Property="BorderBrush" Value="{StaticResource OtherSide_LightGray}" TargetName="OuterBorder" />
                                          </DataTrigger>
                                          <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                             <Setter Property="BorderThickness" Value="0" TargetName="OuterBorder" />
                                             <Setter Property="Background" Value="{Binding ProcessWorkflowHeader_CompletedColor, ElementName=ProcessWorkflowHeaderUserControl}" TargetName="OuterBorder" />
                                             <Setter Property="Visibility" Value="Visible" TargetName="CheckImage" />
                                          </DataTrigger>
                                          <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                             <Setter Property="BorderThickness" Value="3" TargetName="OuterBorder" />
                                             <Setter Property="BorderBrush" Value="{Binding ProcessWorkflowHeader_SelectedColor, ElementName=ProcessWorkflowHeaderUserControl}" TargetName="OuterBorder" />
                                             <Setter Property="Background" Value="Transparent" TargetName="OuterBorder" />
                                             <Setter Property="Visibility" Value="Visible" TargetName="InnerEllipse" />
                                             <Setter Property="Visibility" Value="Collapsed" TargetName="CheckImage" />
                                          </DataTrigger>
                                       </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                 </Setter.Value>
                              </Setter>
                           </Style>
                        </Button.Style>
                     </Button>

                     <Border Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Height="2">
                        <Border.Style>
                           <Style TargetType="{x:Type Border}">
                              <Setter Property="Background" Value="{StaticResource OtherSide_LightGray}" />
                              <Style.Triggers>
                                 <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="Background" Value="{Binding ProcessWorkflowHeader_CompletedColor, ElementName=ProcessWorkflowHeaderUserControl}" />
                                 </DataTrigger>
                              </Style.Triggers>
                           </Style>
                        </Border.Style>
                     </Border>

                     <ToggleButton Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0" HorizontalAlignment="Center" 
                                   Content="{Binding ProcessWorkflowStep.Name}"
                                   Cursor="Hand"
                                   x:Name="ProccesWorkflowStepHeaderToggleButton">
                        <ToggleButton.Style>
                           <Style TargetType="{x:Type ToggleButton}">
                              <Style.Setters>
                                 <Setter Property="Foreground" Value="Gray" />
                                 <Setter Property="Background" Value="Transparent" />
                                 <Setter Property="Template">
                                    <Setter.Value>
                                       <ControlTemplate TargetType="{x:Type ToggleButton}">
                                          <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" 
                                                  Padding="8,4,8,4"
                                                  CornerRadius="8">
                                             <TextBlock Text="{TemplateBinding Content}" />
                                          </Border>
                                       </ControlTemplate>
                                    </Setter.Value>
                                 </Setter>
                              </Style.Setters>
                              <Style.Triggers>
                                 <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="{Binding ProcessWorkflowHeader_CompletedColor, ElementName=ProcessWorkflowHeaderUserControl}" />
                                 </DataTrigger>
                                 <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource OtherSide_LightLightGray}" />
                                 </Trigger>
                                 <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{StaticResource OtherSide_LightLightGray}" />
                                 </Trigger>
                              </Style.Triggers>
                           </Style>
                        </ToggleButton.Style>
                     </ToggleButton>

                     <Popup Style="{StaticResource UiPopup}" 
                            IsOpen="{Binding IsChecked, ElementName=ProccesWorkflowStepHeaderToggleButton}"
                            PlacementTarget="{Binding ElementName=ProccesWorkflowStepHeaderToggleButton}">
                        <ContentControl Style="{StaticResource UiPopupContentStyle}">
                           <Grid>

                              <list:EmptyListIndicator DataContext="{Binding CompletionProcessWorkflowStepConditionViewModels}"
                                                       EmptyListIndicator_BorderThickness="0"
                                                       EmptyListIndicator_Text="Aucune action à effectuer" />

                              <ItemsControl ItemsSource="{Binding CompletionProcessWorkflowStepConditionViewModels}" Margin="12">
                                 <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                       <Grid Height="32">
                                          <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto" />
                                             <ColumnDefinition Width="*" />
                                          </Grid.ColumnDefinitions>

                                          <osc_customcontrols:SvgViewer Grid.Column="0"
                                                                        SvgViewer_ImageGeometry="{StaticResource icon_check}" 
                                                                        SvgViewer_ImageHeight="16" 
                                                                        SvgViewer_ImageColor="Gray"
                                                                        Visibility="{Binding IsConditionVerified, Converter={StaticResource BoolToVisibleOrCollapsed}}"/>

                                          <osc_customcontrols:SvgViewer Grid.Column="0"
                                                                        SvgViewer_ImageGeometry="{StaticResource icon_close}" 
                                                                        SvgViewer_ImageHeight="16" 
                                                                        SvgViewer_ImageColor="{StaticResource OtherSide_Red}"
                                                                        Visibility="{Binding IsConditionVerified, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=invert}"/>

                                          <TextBlock Grid.Column="1" Text="{Binding ProcessWorkflowStepCondition.Description}" VerticalAlignment="Center" Style="{StaticResource PropertyLabelTextBlock}"/>

                                       </Grid>
                                    </DataTemplate>
                                 </ItemsControl.ItemTemplate>
                              </ItemsControl>

                           </Grid>
                        </ContentControl>
                     </Popup>

                  </Grid>

               </Border>
            </DataTemplate>
         </ItemsControl.ItemTemplate>
      </ItemsControl>

   </Grid>
</UserControl>
